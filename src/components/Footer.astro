---
// Footer stays LIGHT (logo on white) — locked brand rule.
// Legal: a single link to the dedicated privacy page (no cookie/terms pages).
import { getLangFromUrl, useTranslations, EMAIL } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const p = (path: string) => (lang === 'en' ? `/en${path === '/' ? '' : path}` : path);

const privacyHref = lang === 'en' ? '/en/privacy' : '/confidentialitate';
const year = new Date().getUTCFullYear();
---

<footer class="border-t border-border bg-surface">
  <div class="container flex flex-col gap-8 py-12 md:flex-row md:items-start md:justify-between">
    <div class="max-w-sm">
      <a href={p('/')} class="flex items-center gap-2.5" aria-label="Smart Control — home">
        <img src="/smartcontrol-mark.png" alt="" width="28" height="28" class="h-7 w-7" />
        <span class="text-base font-bold tracking-tight">
          <span class="text-navy">Smart</span><span class="text-bright">Control</span>
        </span>
      </a>
      <p class="mt-3 font-mono text-small italic text-cool">{t('footer.tagline')}</p>
      <p class="mt-3 text-small text-cool">{t('company.address')}</p>
    </div>

    <div class="flex flex-col gap-2 text-small">
      <a href={`mailto:${EMAIL}`} class="font-semibold text-royal hover:text-navy">{EMAIL}</a>
      <a href={privacyHref} class="text-cool hover:text-navy">{t('footer.privacy')}</a>
    </div>
  </div>

  <div class="border-t border-divider">
    <div class="container py-5 text-small text-faint">
      © {year} {t('company.name')} SRL. {t('footer.rights')}
    </div>
  </div>
</footer>
