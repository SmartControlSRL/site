---
// Export 4-col footer (RESOLUTIONS §17), ALWAYS light. Cols: brand / Servicii /
// Soluții / Contact. NO "Termeni", NO "Cookies", NO "Asset Management". Privacy
// → /confidentialitate (/en/privacy). © year computed. Email obfuscated.
import { getLangFromUrl, useTranslations, localizedPath, EMAIL_USER, EMAIL_DOMAIN } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const p = (path: string) => localizedPath(lang, path);

const privacyHref = lang === 'en' ? '/en/privacy' : '/confidentialitate';
const year = new Date().getUTCFullYear();

const services = [
  { label: t('footer.service.infra'), href: p('/servicii') },
  { label: t('footer.service.security'), href: p('/servicii') },
  { label: t('footer.service.software'), href: p('/servicii') },
  { label: t('footer.service.managed'), href: p('/servicii') },
];
const solutions = [
  { label: t('nav.seknet'), href: p('/solutii/seknet') },
  { label: t('nav.svpn'), href: p('/solutii/s-vpn') },
];
---

<footer class="border-t border-border bg-surface px-6 pb-10 pt-16 md:px-10">
  <div class="mx-auto max-w-[1180px]">
    <div class="grid gap-12 md:grid-cols-[1.4fr_1fr_1fr_1.2fr]">
      <!-- Col 1 — brand -->
      <div>
        <a href={p('/')} class="flex items-center gap-[11px]" aria-label="Smart Control — home">
          <img src="/smartcontrol-mark-96.png" alt="" width="34" height="34" class="h-[34px] w-[34px]" loading="lazy" decoding="async" />
          <span class="text-[17px] font-bold tracking-[-0.3px] text-navy">Smart<span class="text-bright">Control</span></span>
        </a>
        <p class="mt-3.5 text-[13.5px] italic text-cool">{t('footer.tagline')}</p>
        <p class="mt-4 max-w-xs text-[13px] leading-[1.7] text-cool">{t('footer.blurb')}</p>
      </div>

      <!-- Col 2 — Servicii -->
      <div>
        <h2 class="font-mono text-[11px] font-semibold uppercase tracking-[2px] text-cool">{t('footer.col.services')}</h2>
        <ul class="mt-4 grid gap-2.5">
          {services.map((l) => (
            <li><a href={l.href} class="text-[13.5px] text-slate transition-colors hover:text-royal">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Col 3 — Soluții -->
      <div>
        <h2 class="font-mono text-[11px] font-semibold uppercase tracking-[2px] text-cool">{t('footer.col.solutions')}</h2>
        <ul class="mt-4 grid gap-2.5">
          {solutions.map((l) => (
            <li><a href={l.href} class="text-[13.5px] text-slate transition-colors hover:text-royal">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Col 4 — Contact -->
      <div>
        <h2 class="font-mono text-[11px] font-semibold uppercase tracking-[2px] text-cool">{t('footer.col.contact')}</h2>
        <div class="mt-4 grid gap-2.5">
          <a data-email-user={EMAIL_USER} data-email-domain={EMAIL_DOMAIN} href="#" class="text-[13.5px] text-slate transition-colors hover:text-royal"></a>
          <span class="text-[13.5px] text-slate">{t('footer.website')}</span>
          <span class="text-[13.5px] leading-[1.6] text-cool">
            {t('company.address.l1')}<br />{t('company.address.l2')}
          </span>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 flex flex-col items-start gap-4 border-t border-divider pt-6 sm:flex-row sm:items-center sm:justify-between">
      <span class="text-[12.5px] text-cool">© {year} {t('company.name')}. {t('footer.rights')}</span>
      <a href={privacyHref} class="text-[12.5px] text-cool transition-colors hover:text-royal">{t('footer.privacy')}</a>
    </div>
  </div>
</footer>
