---
// Small rounded-full mono label pill. Used for ISO badges, partner names,
// "Nou" badges, capability tags. Variants:
//   light      — cool text, white bg, hairline border (ISO pills)
//   dark       — white text on bright bg (the "Nou" badge)
//   compliance — reserved teal (GDPR / NIS2 / DORA / ISO badge contexts only)
interface Props {
  variant?: 'light' | 'dark' | 'compliance';
  class?: string;
}

const { variant = 'light', class: extra = '' } = Astro.props;

const tone =
  variant === 'dark'
    ? 'bg-royal text-white'
    : variant === 'compliance'
      ? 'bg-compliance-tint text-compliance border border-compliance/30'
      : 'bg-surface text-cool border border-border';
---

<span
  class:list={[
    'inline-block rounded-full font-mono text-[11.5px] uppercase leading-none tracking-[0.5px]',
    'px-3 py-1.5',
    tone,
    extra,
  ]}
>
  <slot />
</span>
