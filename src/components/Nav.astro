---
// Export nav (RESOLUTIONS §16): fixed top, ALWAYS light (logo on white), logo +
// links + assessment CTA (obfuscated mailto) + RO/EN switch. Active-page
// underline by pathname. initNavShrink (wired in BaseLayout) tightens padding +
// adds a hairline/shadow past 24px scroll — it targets [data-nav-shrink].
// Mobile (<768px): hamburger toggles a light slide-down panel (aria-expanded,
// ESC closes, body scroll-lock while open).
import { getLangFromUrl, useTranslations, localizedPath, altLocalePath } from '../i18n/ui';
import MailtoLink from './MailtoLink.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const p = (path: string) => localizedPath(lang, path);

// Two dropdown groups (parent links to the hub/index, panel lists the child
// pages) + a plain Contact anchor. This surfaces every service/solution page
// one hover/tap deep and gives /servicii + /solutii their entry points.
const navItems = [
  {
    href: p('/servicii'),
    label: t('nav.services'),
    children: [
      { href: p('/servicii/cloud'), label: t('nav.cloud') },
      { href: p('/servicii/securitate'), label: t('footer.service.security') },
      { href: p('/servicii/software'), label: t('footer.service.software') },
      { href: p('/servicii/managed'), label: t('footer.service.managed') },
    ],
  },
  {
    href: p('/solutii'),
    label: t('nav.products'),
    children: [
      { href: p('/solutii/seknet'), label: t('nav.seknet') },
      { href: p('/solutii/s-vpn'), label: t('nav.svpn') },
    ],
  },
  { href: p('/#contact'), label: t('nav.contact') },
];

// Active-page underline: compare against the current pathname (ignore anchors).
const here = Astro.url.pathname.replace(/\/$/, '') || '/';
const cleanPath = (href: string) => href.split('#')[0].replace(/\/$/, '') || '/';
// Exact match — for leaf links (children, Contact).
const isActive = (href: string) => {
  const clean = cleanPath(href);
  return clean !== '/' && clean !== p('/') && here === clean;
};
// Tree match — a parent is active on its hub page or any descendant page.
const inTree = (href: string) => {
  const clean = cleanPath(href);
  if (clean === '/' || clean === p('/')) return false;
  return here === clean || here.startsWith(clean + '/');
};

// Language switch → the alternate-locale version of this page.
const path = Astro.url.pathname;
const altHref = altLocalePath(path);
---

<header class="fixed inset-x-0 top-0 z-50">
  <nav
    data-nav-shrink
    aria-label="Primary"
    class="border-b border-transparent bg-surface px-10 py-[18px] transition-[padding,box-shadow,border-color] duration-300 ease-[cubic-bezier(0.16,1,0.3,1)]"
  >
    <div class="mx-auto flex max-w-[1180px] items-center justify-between gap-8">
      <!-- Logo -->
      <a href={p('/')} class="flex shrink-0 items-center gap-[11px]" aria-label="Smart Control — home">
        <img src="/smartcontrol-mark-96.png" alt="" width="34" height="34" class="h-[34px] w-[34px]" decoding="async" />
        <span class="text-[17px] font-bold tracking-[-0.3px] text-navy">Smart<span class="text-bright">Control</span></span>
      </a>

      <!-- Desktop links -->
      <ul class="hidden items-center gap-7 md:flex">
        {
          navItems.map((item) =>
            item.children ? (
              <li class="group relative">
                <a
                  href={item.href}
                  aria-current={inTree(item.href) ? 'page' : undefined}
                  aria-haspopup="true"
                  class:list={[
                    'inline-flex items-center gap-[5px] border-b-2 pb-[3px] text-[13.5px] no-underline transition-colors hover:border-bright hover:text-navy',
                    inTree(item.href)
                      ? 'border-bright font-semibold text-navy'
                      : 'border-transparent font-medium text-slate',
                  ]}
                >
                  {item.label}
                  <svg
                    width="13"
                    height="13"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    class="transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180"
                  >
                    <polyline points="6 9 12 15 18 9" />
                  </svg>
                </a>
                {/* Dropdown panel — pt-3 is a hover bridge over the gap to the trigger */}
                <div class="invisible absolute left-1/2 top-full z-10 -translate-x-1/2 translate-y-1 pt-3 opacity-0 transition-[opacity,transform] duration-200 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:visible group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:visible group-focus-within:translate-y-0 group-focus-within:opacity-100">
                  <ul class="min-w-[232px] rounded-xl border border-border bg-surface p-2 [box-shadow:0_12px_32px_rgba(14,31,91,0.16)]">
                    {item.children.map((c) => (
                      <li>
                        <a
                          href={c.href}
                          aria-current={isActive(c.href) ? 'page' : undefined}
                          class:list={[
                            'block rounded-md px-3 py-2.5 text-[13.5px] no-underline transition-colors hover:bg-blue-wash hover:text-navy',
                            isActive(c.href) ? 'font-semibold text-navy' : 'font-medium text-slate',
                          ]}
                        >
                          {c.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </li>
            ) : (
              <li>
                <a
                  href={item.href}
                  aria-current={isActive(item.href) ? 'page' : undefined}
                  class:list={[
                    'border-b-2 pb-[3px] text-[13.5px] no-underline transition-colors hover:border-bright hover:text-navy',
                    isActive(item.href)
                      ? 'border-bright font-semibold text-navy'
                      : 'border-transparent font-medium text-slate',
                  ]}
                >
                  {item.label}
                </a>
              </li>
            )
          )
        }
      </ul>

      <!-- Right cluster -->
      <div class="flex items-center gap-3">
        <a
          href={altHref}
          class="text-[13.5px] font-semibold text-cool transition-colors hover:text-navy"
          aria-label={t('lang.switch.aria')}
        >
          {t('lang.switch')}
        </a>
        <MailtoLink
          variant="button"
          subject={t('subject.assessment')}
          class="!hidden !px-[18px] !py-[9px] !text-[13.5px] md:!inline-flex"
        >
          {t('cta.assessment')}
        </MailtoLink>

        <!-- Mobile hamburger -->
        <button
          type="button"
          data-nav-toggle
          aria-expanded="false"
          aria-controls="nav-mobile-panel"
          aria-label={t('nav.menu.open')}
          data-label-open={t('nav.menu.open')}
          data-label-close={t('nav.menu.close')}
          class="flex h-10 w-10 items-center justify-center rounded-md text-navy transition-colors hover:bg-blue-wash md:hidden"
        >
          <svg data-nav-icon-open width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
          <svg data-nav-icon-close width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="hidden" aria-hidden="true">
            <line x1="6" y1="6" x2="18" y2="18"></line>
            <line x1="18" y1="6" x2="6" y2="18"></line>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile slide-down panel -->
  <div
    id="nav-mobile-panel"
    data-nav-panel
    hidden
    class="border-b border-border bg-surface shadow-md md:hidden"
  >
    <ul class="mx-auto flex max-w-[1180px] flex-col gap-1 px-6 py-4">
      {
        navItems.map((item) =>
          item.children ? (
            <li>
              <a
                href={item.href}
                aria-current={inTree(item.href) ? 'page' : undefined}
                class:list={[
                  'block rounded-md px-3 py-3 text-[15px] transition-colors hover:bg-blue-wash',
                  inTree(item.href) ? 'font-semibold text-navy' : 'font-medium text-slate',
                ]}
              >
                {item.label}
              </a>
              <ul class="mb-1 ml-3 flex flex-col gap-0.5 border-l border-divider pl-3">
                {item.children.map((c) => (
                  <li>
                    <a
                      href={c.href}
                      aria-current={isActive(c.href) ? 'page' : undefined}
                      class:list={[
                        'block rounded-md px-3 py-2.5 text-[14px] transition-colors hover:bg-blue-wash hover:text-navy',
                        isActive(c.href) ? 'font-semibold text-navy' : 'font-medium text-cool',
                      ]}
                    >
                      {c.label}
                    </a>
                  </li>
                ))}
              </ul>
            </li>
          ) : (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
                class:list={[
                  'block rounded-md px-3 py-3 text-[15px] transition-colors hover:bg-blue-wash',
                  isActive(item.href) ? 'font-semibold text-navy' : 'font-medium text-slate',
                ]}
              >
                {item.label}
              </a>
            </li>
          )
        )
      }
      <li class="mt-2 px-3">
        <MailtoLink variant="button" dark subject={t('subject.assessment')} class="w-full">
          {t('cta.assessment')}
        </MailtoLink>
      </li>
    </ul>
  </div>
</header>

<script>
  // Mobile menu: toggle the slide-down panel, swap icon, lock body scroll, ESC
  // closes. Re-bound on every View Transition page load. Idempotent via a flag.
  function wireMobileNav() {
    const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
    const panel = document.querySelector<HTMLElement>('[data-nav-panel]');
    if (!toggle || !panel) return;
    const iconOpen = toggle.querySelector<SVGElement>('[data-nav-icon-open]');
    const iconClose = toggle.querySelector<SVGElement>('[data-nav-icon-close]');

    let open = false;
    const set = (next: boolean) => {
      open = next;
      toggle.setAttribute('aria-expanded', String(open));
      const label = open ? toggle.dataset.labelClose : toggle.dataset.labelOpen;
      if (label) toggle.setAttribute('aria-label', label);
      panel.hidden = !open;
      iconOpen?.classList.toggle('hidden', open);
      iconClose?.classList.toggle('hidden', !open);
      document.body.style.overflow = open ? 'hidden' : '';
    };
    set(false);

    toggle.addEventListener('click', () => set(!open));
    panel.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => set(false)));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && open) {
        set(false);
        toggle.focus();
      }
    });
  }

  document.addEventListener('astro:page-load', wireMobileNav);
</script>
