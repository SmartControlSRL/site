---
// SEKNET — product detail (Template A). RO default at /solutii/seknet.
// Dark product hero (network canvas) → light 5-module deep-dive → mono spec
// table (gray-wash band) → cross-sell pair (S-VPN; Asset Management BANNED) →
// dark CTA band → shared footer. Motion is wired purely via data-* attributes
// picked up by BaseLayout; canvas opts come from the spec verbatim.
import BaseLayout from '../../layouts/BaseLayout.astro';
import NetworkCanvas from '../../components/NetworkCanvas.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import ModuleCard from '../../components/ModuleCard.astro';
import SpecTable from '../../components/SpecTable.astro';
import CtaBand from '../../components/CtaBand.astro';
import MailtoLink from '../../components/MailtoLink.astro';
import { getLangFromUrl, useTranslations, localizedPath } from '../../i18n/ui';
import {
  FingerprintPattern,
  Shield,
  Activity,
  LayoutDashboard,
  Radar,
  CloudCog,
  Lock,
} from '@lucide/astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const p = (path: string) => localizedPath(lang, path);

const title = 'SEKNET — Monitorizare, securitate și control | Smart Control';
const description =
  'SEKNET: platformă enterprise integrată de monitorizare, securitate cibernetică și management al identității — cinci module specializate, arhitectură cloud-native, ≥ 50.000 EPS / nod, scalare fără costuri de licențiere adiționale.';

// Hero stat row (4 mono pills, ▸-prefixed).
const heroStats = [
  '≥ 50.000 EPS per nod',
  '< 1s latență indexare',
  'Multi-tenancy, izolare per tenant',
  'Stocare istorică nelimitată',
];

// Mono spec table rows (verbatim, "·"-delimited). ISO 27701 NOT present.
const specRows = [
  {
    label: 'Performanță',
    value:
      '≥ 50.000 EPS / nod · indexare < 1s · căutare < 5s pe 100 GB · alertă < 60s · overhead agent < 1% CPU',
  },
  {
    label: 'Scalabilitate',
    value:
      '1.000+ surse simultane · ≥ 10 GB/zi fără plafon · scalare orizontală fără downtime · multi-tenancy cu izolare completă',
  },
  {
    label: 'Continuitate',
    value: 'RTO < 4h · RPO < 1h · failover < 30s · rolling updates fără întrerupere · replicare ≥ 2x',
  },
  {
    label: 'Securitate',
    value:
      'TLS 1.2 / 1.3 în tranzit · AES-256 la repaus · jurnal audit tamper-proof · secrete în vault (K8s Secrets) · hardening CIS Level 1 implicit',
  },
  {
    label: 'Integrări',
    value:
      'API REST (OpenAPI/Swagger) · ServiceNow, Jira, Zendesk · SOAR — Splunk, IBM, TheHive · email, Slack, Teams, SNS, PagerDuty, webhooks',
  },
  {
    label: 'Deployment',
    value:
      'Cloud-native, microservicii containerizate · on-premise, hibrid sau cloud (AWS, Azure, GCP) · agenți Windows, Linux, macOS, Solaris, AIX, HP-UX · interfață ro-RO și en-US',
  },
];

// JSON-LD: Product (SEKNET, brand Smart Control) — no price.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'SEKNET',
  brand: { '@type': 'Brand', name: 'Smart Control' },
  category: 'Enterprise security & monitoring platform',
  description:
    'Platformă enterprise integrată de monitorizare, securitate cibernetică și management al identității — cinci module specializate (Identity, Shield, Insight, View, Trap), arhitectură cloud-native pe microservicii.',
  url: 'https://smartcontrol.ro/solutii/seknet',
  manufacturer: { '@type': 'Organization', name: 'Smart Control SRL', url: 'https://smartcontrol.ro' },
};
---

<BaseLayout title={title} description={description}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  {/* ─── 2. PRODUCT HERO (dark + network) ─────────────────────────────── */}
  <header class="relative overflow-hidden bg-midnight">
    <NetworkCanvas lineAlpha={0.24} dotAlpha={0.6} spread={18000} lineDist={155} opacity={0.75} />
    <div
      class="pointer-events-none absolute inset-0"
      style="background:radial-gradient(ellipse 75% 65% at 35% 40%, rgba(4,12,43,0) 0%, rgba(4,12,43,0.5) 60%, #040C2B 100%)"
      aria-hidden="true"
    >
    </div>

    <div
      data-hero-scrub
      class="relative z-[1] mx-auto max-w-[1180px] px-6 pb-[120px] pt-[150px] sm:px-10 sm:pt-[190px]"
    >
      <span
        class="sc-hero-eyebrow inline-block border-b-2 border-[rgba(122,180,232,0.3)] pb-2.5 font-mono text-[12.5px] font-medium uppercase tracking-[2.5px] text-sky"
      >
        Produs proprietar · Fișa de specificații v2.3
      </span>

      <h1
        class="mt-[26px] max-w-[840px] text-[clamp(2.5rem,1.9rem+2.6vw,3.875rem)] font-extrabold leading-[1.08] tracking-[-2px] text-white"
      >
        <span class="sc-word sc-word-1 inline-block text-white">SEKNET.</span>{' '}
        <span class="sc-word sc-word-2 inline-block text-sky">Monitorizare.</span>
        <br />
        <span class="sc-word sc-word-3 inline-block text-sky">Securitate.</span>{' '}
        <span class="sc-word sc-word-4 inline-block text-sky">Control.</span>
      </h1>

      <p
        class="sc-hero-lead mt-[26px] max-w-[640px] text-[18px] leading-[1.7] text-[rgba(226,233,245,0.72)]"
      >
        Platformă enterprise integrată de monitorizare, securitate cibernetică și management al
        identității — <strong class="font-semibold text-white">cinci module specializate</strong>,
        arhitectură cloud-native pe microservicii, scalare orizontală nelimitată <strong
          class="font-semibold text-white">fără costuri de licențiere adiționale</strong
        >.
      </p>

      <div class="sc-hero-cta mt-[38px] flex flex-wrap items-center gap-4">
        <MailtoLink variant="button" dark subject={t('subject.demo.seknet')}>
          {t('cta.demo.seknet')}
        </MailtoLink>
        <a
          href="#module"
          class="px-2 py-[13px] text-[14.5px] font-semibold text-sky transition-colors hover:text-white"
        >
          Vezi modulele <span aria-hidden="true">›</span>
        </a>
      </div>

      <ul class="sc-hero-stats mt-[56px] flex flex-wrap gap-x-5 gap-y-3 sm:gap-x-9">
        {
          heroStats.map((s) => (
            <li class="font-mono text-[12.5px] text-[rgba(226,233,245,0.55)]">
              <span class="text-sky" aria-hidden="true">
                ▸
              </span>{' '}
              {s}
            </li>
          ))
        }
      </ul>
    </div>
  </header>

  {/* ─── 3. MODULE (light deep-dive, 5 modules) ───────────────────────── */}
  <section id="module" class="bg-surface px-6 py-[72px] sm:px-10 sm:py-[110px]">
    <div class="mx-auto max-w-[1180px]">
      <div data-reveal>
        <SectionHeading
          eyebrow="Module"
          heading="Cinci module specializate, o singură sursă de adevăr"
          variant="light"
          headingMaxWidth="700px"
        >
          50 de specificații funcționale și 30 non-funcționale, documentate în fișa tehnică v2.3 —
          fiecare capabilitate aparține unui modul, totul operat dintr-o singură interfață.
        </SectionHeading>
      </div>

      <div data-skew="4" class="mt-[52px] grid grid-cols-1 gap-5 md:grid-cols-6">
        {/* Card 1 — Identity (span 2) */}
        <div
          class="md:col-span-3 lg:col-span-2"
          data-reveal
          data-reveal-rotate="-4"
          data-drift="0.07"
        >
          <ModuleCard
            kicker="Seknet"
            title="Identity"
            body="Management identitate și acces (IAM)."
            items={[
              'SSO — OAuth2, OIDC, SAML 2.0',
              'MFA — TOTP, WebAuthn / FIDO2',
              'RBAC granular + Segregation of Duties',
              'AD / LDAP / RADIUS nativ',
              'Provizionare automată SCIM 2.0',
            ]}
            cols={1}
          >
            <FingerprintPattern slot="icon" class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
          </ModuleCard>
        </div>

        {/* Card 2 — Shield (span 2) */}
        <div
          class="md:col-span-3 lg:col-span-2"
          data-reveal
          data-reveal-delay="80"
          data-reveal-rotate="4"
        >
          <ModuleCard
            kicker="Seknet"
            title="Shield"
            body="SIEM și securitate cibernetică."
            items={[
              'Corelație multi-sursă + MITRE ATT&CK',
              'IDS — semnături și comportament',
              'File Integrity Monitoring în timp real',
              'Threat intel — VirusTotal, OTX, MISP',
              'Răspuns activ — blocare IP, izolare endpoint',
            ]}
            cols={1}
          >
            <Shield slot="icon" class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
          </ModuleCard>
        </div>

        {/* Card 3 — Insight (span 2) */}
        <div
          class="md:col-span-6 lg:col-span-2"
          data-reveal
          data-reveal-delay="160"
          data-reveal-rotate="-4"
          data-drift="-0.07"
        >
          <ModuleCard
            kicker="Seknet"
            title="Insight"
            body="Analiză, căutare și stocare date."
            items={[
              'Căutare distribuită, indexare în timp real',
              'Query DSL, Lucene sau SQL',
              'Stocare istorică nelimitată — zero cost / GB',
              'ML nativ — anomalii spike & drop',
              'API RESTful — OpenAPI / Swagger',
            ]}
            cols={1}
          >
            <Activity slot="icon" class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
          </ModuleCard>
        </div>

        {/* Card 4 — View (span 3, two-column bullets) */}
        <div class="md:col-span-3" data-reveal data-reveal-rotate="4" data-drift="0.07">
          <ModuleCard
            kicker="Seknet"
            title="View"
            body="Interfață unificată și RBAC avansat."
            items={[
              '200+ dashboard-uri predefinite',
              'Hartă topologică interactivă',
              'Rapoarte automate PDF / CSV',
              'Acces vizualizare per rol',
              'Conformitate PCI-DSS, HIPAA, GDPR, NIS 2, ISO 27001',
            ]}
            cols={2}
          >
            <LayoutDashboard slot="icon" class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
          </ModuleCard>
        </div>

        {/* Card 5 — Trap (span 3, DARK featured) */}
        <div
          class="md:col-span-3"
          data-reveal
          data-reveal-delay="80"
          data-reveal-rotate="-4"
          data-drift="-0.07"
        >
          <ModuleCard
            variant="dark"
            kicker="Seknet"
            title="Trap"
            badge="Nou în v2.3"
            cols={2}
          >
            <Radar slot="icon" class="h-[22px] w-[22px] text-sky" stroke-width={1.5} />
            <p class="mt-4 text-[13.5px] text-[rgba(226,233,245,0.7)]">
              Detecție activă prin decepție și honeypot — orice interacțiune e prin definiție
              malițioasă: <strong class="text-white">zero fals-pozitive</strong>.
            </p>
            <ul class="mt-4 grid gap-y-2 sm:grid-cols-2 sm:gap-x-6">
              {
                [
                  'Honeypot-uri — 20+ protocoale',
                  'Detecție mișcare laterală',
                  'Capturare sesiuni + export IoC',
                  'IDS rețea — scan, exploit, C2',
                  'Hartă de atac live cu geolocație',
                  'Honeypot-uri LLM — servicii simulate',
                ].map((item) => (
                  <li class="flex text-[13.5px] leading-snug text-[rgba(226,233,245,0.85)]">
                    <span class="mr-2 shrink-0 text-sky" aria-hidden="true">
                      ›
                    </span>
                    <span>{item}</span>
                  </li>
                ))
              }
            </ul>
          </ModuleCard>
        </div>
      </div>
    </div>
  </section>

  {/* ─── 4. SPEC TABLE (mono, gray-wash band) ─────────────────────────── */}
  <section data-band class="bg-page px-6 py-[72px] sm:px-10 sm:py-[110px]">
    <div class="mx-auto max-w-[1180px]">
      <div data-reveal>
        <SectionHeading
          eyebrow="Specificații · v2.3"
          heading="Specificații documentate, negru pe alb"
          variant="light"
        />
      </div>

      {/* Giant-number stat strip — static (NO data-count). */}
      <div
        class="mt-11 grid grid-cols-2 gap-px overflow-hidden rounded-xl border border-border bg-border shadow-sm md:grid-cols-4"
        data-reveal
      >
        {
          [
            { num: '50K', accent: '+', caption: 'Evenimente / secundă / nod' },
            { num: '<1', accent: 's', caption: 'Latență indexare' },
            { num: '10GB', accent: '+', caption: 'Ingestie zilnică, fără plafon' },
            { num: '∞', accent: '', caption: 'Retenție date — zero cost licență' },
          ].map((cell) => (
            <div class="bg-surface px-7 py-7 transition-colors duration-[350ms] ease-[cubic-bezier(0.16,1,0.3,1)] hover:bg-[#F8FAFF]">
              <div class="font-mono text-[34px] font-semibold leading-none text-navy">
                {cell.num}
                {cell.accent && <span class="text-bright">{cell.accent}</span>}
              </div>
              <div class="mt-2.5 text-[13.5px] text-cool">{cell.caption}</div>
            </div>
          ))
        }
      </div>

      <div class="mt-5" data-reveal data-drift="-0.04">
        <SpecTable rows={specRows} />
      </div>
    </div>
  </section>

  {/* ─── 5. ALTE PRODUSE ("Din aceeași familie", light) ───────────────── */}
  <section class="bg-surface px-6 py-[72px] sm:px-10 sm:py-[110px]">
    <div class="mx-auto max-w-[1180px]">
      <div data-reveal>
        <SectionHeading eyebrow="Din aceeași familie" heading="Completează platforma" variant="light" />
      </div>

      <div class="mt-11 grid grid-cols-1 gap-5 md:grid-cols-2">
        {/* Card A — S-VPN (clickable link card) */}
        <div data-reveal data-drift="0.06">
          <a
            href={p('/solutii/s-vpn')}
            class="group flex h-full items-start gap-5 rounded-xl border border-border bg-surface p-[30px] no-underline shadow-sm transition-all duration-[350ms] ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-[5px] hover:border-border-blue hover:shadow-lg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-bright sm:px-[34px]"
          >
            <span
              class="flex h-11 w-11 shrink-0 items-center justify-center rounded-md border border-border-blue bg-blue-wash"
            >
              <Lock class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
            </span>
            <span class="block">
              <span class="block text-[18px] font-bold text-navy">S-VPN</span>
              <span class="mt-2 block text-[14px] leading-[1.65] text-cool">
                Suită integrată de acces remote securizat — VPN, MFA, WAF, Endpoint și Console, la
                −60% față de Cisco / Fortinet.
              </span>
              <span class="mt-3 inline-block text-[13.5px] font-semibold text-royal">
                Explorează S-VPN <span aria-hidden="true">›</span>
              </span>
            </span>
          </a>
        </div>

        {/* Card B — Cloud & Modernizare cross-sell (Asset Management BANNED, RESOLUTIONS §9;
            Cloud chosen over a second S-VPN card to avoid duplicate targets) */}
        <div data-reveal data-reveal-delay="100" data-drift="-0.06">
          <a
            href={p('/servicii/cloud')}
            class="group flex h-full items-start gap-5 rounded-xl border border-border bg-surface p-[30px] no-underline shadow-sm transition-all duration-[350ms] ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-[5px] hover:border-border-blue hover:shadow-lg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-bright sm:px-[34px]"
          >
            <span
              class="flex h-11 w-11 shrink-0 items-center justify-center rounded-md border border-border-blue bg-blue-wash"
            >
              <CloudCog class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
            </span>
            <span class="block">
              <span class="block text-[18px] font-bold text-navy">Modernizare cu securitate integrată</span>
              <span class="mt-2 block text-[14px] leading-[1.65] text-cool">
                Re-arhitecturăm infrastructura cu securitate din prima zi — metodologie în
                5 etape, business case cu ROI estimat și raport ROI la 90 de zile.
              </span>
              <span class="mt-3 inline-block text-[13.5px] font-semibold text-royal">
                Explorează Cloud & Modernizare <span aria-hidden="true">›</span>
              </span>
            </span>
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* ─── 6. CTA (dark band + network) ─────────────────────────────────── */}
  <CtaBand
    id="contact"
    eyebrow="Demo live"
    heading="Vezi SEKNET pe infrastructura ta"
    cta={t('cta.demo.seknet')}
    subject={t('subject.demo.seknet')}
  >
    Demo pe un mediu de test cu datele tale reale — nu un slide deck. Programăm în aceeași
    săptămână.
  </CtaBand>
</BaseLayout>

<style>
  /* Hero entry animations (export <helmet>): the keyframes live in global.css;
     here we set the initial hidden state + staggered timings. Collapsed to a
     resting visible state under prefers-reduced-motion (handled globally). */
  .sc-hero-eyebrow {
    opacity: 0;
    animation: scFadeIn 0.8s ease-out 0.1s forwards;
  }
  .sc-word {
    opacity: 0;
    animation: scWordIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .sc-word-1 {
    animation-delay: 0.25s;
  }
  .sc-word-2 {
    animation-delay: 0.45s;
  }
  .sc-word-3 {
    animation-delay: 0.62s;
  }
  .sc-word-4 {
    animation-delay: 0.79s;
  }
  .sc-hero-lead {
    opacity: 0;
    animation: scFadeIn 0.9s ease-out 1s forwards;
  }
  .sc-hero-cta {
    opacity: 0;
    animation: scFadeIn 0.9s ease-out 1.2s forwards;
  }
  .sc-hero-stats {
    opacity: 0;
    animation: scFadeIn 0.9s ease-out 1.4s forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .sc-hero-eyebrow,
    .sc-word,
    .sc-hero-lead,
    .sc-hero-cta,
    .sc-hero-stats {
      opacity: 1;
    }
  }
</style>
