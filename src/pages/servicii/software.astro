---
/**
 * /servicii/software — Software & Automatizare
 * Template B (lighter service page). Source: oferta-servicii.txt §§ Software/Blockchain/AI.
 * Capabilities: custom dev & API-uri, DevOps/DevSecOps & CI/CD, migrare & modernizare,
 * blockchain (Hyperledger, Multichain), automatizare AI/LLM, consultanță arhitecturală,
 * staff augmentation.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Eyebrow from '../../components/Eyebrow.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import ModuleCard from '../../components/ModuleCard.astro';
import StatStrip from '../../components/StatStrip.astro';
import StatBlock from '../../components/StatBlock.astro';
import ChevronList from '../../components/ChevronList.astro';
import MonoPill from '../../components/MonoPill.astro';
import CtaBand from '../../components/CtaBand.astro';
import TextLink from '../../components/TextLink.astro';
import MailtoLink from '../../components/MailtoLink.astro';

import {
  getLangFromUrl,
  useTranslations,
  localizedPath,
  yearsInBusiness,
} from '../../i18n/ui';

import {
  Code,
  GitBranch,
  Layers,
  Link2,
  Bot,
  Puzzle,
  Users,
  ArrowRight,
  FileText,
  MessageSquare,
  FileChartColumn,
  Workflow,
  TriangleAlert,
} from '@lucide/astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const p = (path: string) => localizedPath(lang, path);
const years = yearsInBusiness(new Date().getUTCFullYear());

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Software & Automatizare',
  description:
    'Dezvoltare software custom, DevOps/DevSecOps, migrare și modernizare aplicații, soluții blockchain enterprise, automatizare cu AI/LLM, consultanță arhitecturală și staff augmentation.',
  provider: {
    '@type': 'Organization',
    name: 'Smart Control SRL',
    url: 'https://smartcontrol.ro',
  },
  url: 'https://smartcontrol.ro/servicii/software',
  areaServed: ['RO', 'EU'],
  serviceType: [
    'Custom Software Development',
    'DevOps',
    'DevSecOps',
    'Application Migration',
    'Blockchain Development',
    'AI Automation',
    'Architecture Consulting',
    'Staff Augmentation',
  ],
};
---

<BaseLayout
  title="Software & Automatizare — Smart Control"
  description="Dezvoltare software custom, DevOps/DevSecOps & CI/CD, migrare și modernizare aplicații, soluții blockchain enterprise și automatizare cu AI/LLM. Echipă proprie, cod sursă inclus."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- ═══════════════════════════════════════════════════════════
       HERO — light gradient
       ═══════════════════════════════════════════════════════════ -->
  <header
    class="relative overflow-hidden"
    style="background:linear-gradient(180deg,#F3F6FC 0%,#FFFFFF 100%)"
  >
    <!-- decorative parallax blob -->
    <div
      class="pointer-events-none absolute"
      style="inset:0"
      aria-hidden="true"
      data-parallax="0.3"
    >
      <div
        style="width:640px;height:640px;border-radius:999px;background:radial-gradient(circle,rgba(122,180,232,0.18),rgba(122,180,232,0) 65%);position:absolute;top:-140px;right:-120px;animation:scDriftA 20s ease-in-out infinite alternate"
      >
      </div>
    </div>

    <div class="container" style="padding-top:190px;padding-bottom:100px">
      <div data-hero-scrub>
        <Eyebrow variant="hero">Software &amp; Automatizare</Eyebrow>

        <h1
          class="mt-6 font-extrabold leading-[1.1] tracking-[-1.8px] text-midnight"
          style="font-size:clamp(2.25rem, 1.4rem + 3.6vw, 3.625rem);max-width:880px"
        >
          Aplicații livrate de<br />
          <span class="text-bright">echipă proprie, cod sursă inclus.</span>
        </h1>

        <p
          class="mt-6 text-cool"
          style="font-size:18px;line-height:1.7;max-width:640px;animation:scFadeIn 0.9s ease-out 1.2s both"
        >
          De la arhitectura inițială până la deployment în producție — custom dev, DevSecOps,
          migrări, blockchain enterprise și automatizare cu AI.
          <strong class="text-navy font-semibold">Abordare consultativă, fără subcontractori.</strong>
        </p>

        <div
          class="mt-9 flex flex-wrap items-center gap-4"
          style="animation:scFadeIn 0.9s ease-out 1.4s both"
        >
          <MailtoLink variant="button" subject={t('subject.assessment')}>
            {t('cta.assessment')}
          </MailtoLink>
          <TextLink href="#capabilitati">
            Vezi capabilitățile
          </TextLink>
        </div>
      </div>
    </div>
  </header>

  <!-- ═══════════════════════════════════════════════════════════
       STAT STRIP
       ═══════════════════════════════════════════════════════════ -->
  <section aria-label="Statistici" class="bg-surface">
    <div class="container py-0">
      <StatStrip>
        <StatBlock value="650" count={650} suffix="+" caption="Proiecte livrate" />
        <StatBlock value="250" count={250} suffix="+" caption="Clienți satisfăcuți" />
        <StatBlock value="25" count={25} suffix="+" caption="Clienți internaționali" />
        <StatBlock
          value={String(years)}
          count={years}
          suffix="+"
          caption="Ani de experiență"
        />
      </StatStrip>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       "DE CE SMART CONTROL" — 3 context cards
       ═══════════════════════════════════════════════════════════ -->
  <section class="bg-surface pt-10 pb-[72px] sm:pb-[110px]">
    <div class="container">
      <div data-reveal>
        <SectionHeading
          eyebrow="Abordare"
          heading="Software livrat ca serviciu integrat, nu ca outsourcing clasic"
          headingMaxWidth="700px"
        >
          50 de specialiști interni înlocuiesc modelul clasic de subcontractare: un singur punct de
          contact, responsabilitate end-to-end și cod sursă disponibil la livrare.
        </SectionHeading>
      </div>

      <div class="mt-11 grid gap-5 md:grid-cols-3" data-skew="4">
        <!-- Card 1 -->
        <div data-reveal data-reveal-rotate="-4" data-drift="0.07">
          <div
            class="h-full rounded-xl border border-border bg-surface p-[30px] shadow-sm transition-all duration-[350ms] ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-[5px] hover:border-border-blue hover:shadow-lg"
          >
            <div
              class="flex h-11 w-11 items-center justify-center rounded-md border border-border-blue bg-blue-wash"
            >
              <Code class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
            </div>
            <h3 class="mt-[18px] text-[17px] font-bold text-navy">Cod sursă inclus</h3>
            <p class="mt-[10px] text-[14px] leading-[1.65] text-cool">
              Livrăm codul sursă complet la finalul fiecărui proiect — fără dependență de vendor,
              adaptare totală la cerințele specifice, cu documentație integrată.
            </p>
          </div>
        </div>

        <!-- Card 2 -->
        <div data-reveal data-reveal-delay="100" data-reveal-rotate="4">
          <div
            class="h-full rounded-xl border border-border bg-surface p-[30px] shadow-sm transition-all duration-[350ms] ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-[5px] hover:border-border-blue hover:shadow-lg"
          >
            <div
              class="flex h-11 w-11 items-center justify-center rounded-md border border-border-blue bg-blue-wash"
            >
              <Puzzle class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
            </div>
            <h3 class="mt-[18px] text-[17px] font-bold text-navy">Echipă proprie</h3>
            <p class="mt-[10px] text-[14px] leading-[1.65] text-cool">
              Ingineri și arhitecți interni — nu subcontractori. Cunoașterea acumulată rămâne în
              proiect de la design până la post-lansare.
            </p>
          </div>
        </div>

        <!-- Card 3 -->
        <div data-reveal data-reveal-delay="200" data-reveal-rotate="-4" data-drift="-0.07">
          <div
            class="h-full rounded-xl border border-border bg-surface p-[30px] shadow-sm transition-all duration-[350ms] ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-[5px] hover:border-border-blue hover:shadow-lg"
          >
            <div
              class="flex h-11 w-11 items-center justify-center rounded-md border border-border-blue bg-blue-wash"
            >
              <ArrowRight class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
            </div>
            <h3 class="mt-[18px] text-[17px] font-bold text-navy">Abordare consultativă</h3>
            <p class="mt-[10px] text-[14px] leading-[1.65] text-cool">
              Fiecare proiect pornește de la analiza cerințelor reale și a ROI-ului așteptat — nu
              de la o soluție standard rescrisă pentru context nou.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       CAPABILITĂȚI — bento grid (#capabilitati)
       ═══════════════════════════════════════════════════════════ -->
  <section id="capabilitati" class="bg-page py-[72px] sm:py-[110px]" data-band>
    <div class="container">
      <div data-reveal>
        <SectionHeading
          eyebrow="Capabilități"
          heading="Ce livrăm concret"
          headingMaxWidth="680px"
        >
          Șase domenii de livrare, acoperite de echipa internă Smart Control — de la design
          arhitectural la producție și operare continuă.
        </SectionHeading>
      </div>

      <div class="mt-11 grid gap-5 sm:grid-cols-2 lg:grid-cols-3" data-skew="4">
        <!-- 1. Custom dev & API -->
        <div data-reveal data-reveal-rotate="-4">
          <ModuleCard
            title="Dezvoltare software custom & API"
            index="01"
            body="Aplicații web, API-uri RESTful și microservicii scalabile, integrare între sisteme eterogene, platforme cloud și surse de date legacy."
            items={[
              'Aplicații web & microservicii scalabile',
              'API-uri RESTful documentate (OpenAPI)',
              'Integrare sisteme eterogene & cloud',
              'Automatizare procese interne',
            ]}
            cols={1}
          >
            <Code slot="icon" class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
          </ModuleCard>
        </div>

        <!-- 2. DevOps / DevSecOps & CI/CD -->
        <div data-reveal data-reveal-delay="80" data-reveal-rotate="4">
          <ModuleCard
            title="DevOps / DevSecOps & CI/CD"
            index="02"
            body="Pipeline-uri CI/CD cu security gates, practici DevSecOps pentru livrare continuă și sigură, Infrastructure-as-Code și testare automată în staging."
            items={[
              'Pipeline-uri CI/CD cu security gates',
              'Infrastructure-as-Code',
              'Testare automată în staging',
              'Strategie DevSecOps end-to-end',
            ]}
            cols={1}
          >
            <GitBranch slot="icon" class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
          </ModuleCard>
        </div>

        <!-- 3. Migrare & modernizare -->
        <div data-reveal data-reveal-delay="160" data-reveal-rotate="-4">
          <ModuleCard
            title="Migrare & modernizare aplicații"
            index="03"
            body="Refactoring, re-platforming și re-architecting pentru aplicații existente — containerizare Kubernetes-ready cu zero-downtime și rollback planificat."
            items={[
              'Refactoring, re-platforming, re-architecting',
              'Containerizare & Kubernetes-ready',
              'Migrare zero-downtime',
              'Rollback planificat & staging',
            ]}
            cols={1}
          >
            <Layers slot="icon" class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
          </ModuleCard>
        </div>

        <!-- 4. Blockchain -->
        <div data-reveal>
          <ModuleCard
            title="Blockchain enterprise"
            index="04"
            body="Proiectare și implementare soluții blockchain — smart contracts, tokenizare active digitale, control acces on-chain — acolo unde trasabilitatea și imutabilitatea aduc valoare reală."
            items={[
              'Hyperledger & Multichain',
              'Smart contracts & audit de securitate',
              'Tokenizare active digitale (ERC-20 / ERC-721)',
              'Aplicații descentralizate (dApps)',
            ]}
            cols={1}
          >
            <Link2 slot="icon" class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
          </ModuleCard>
        </div>

        <!-- 5. AI / LLM automation -->
        <div data-reveal data-reveal-delay="80">
          <ModuleCard
            title="Automatizare cu AI / LLM"
            index="05"
            body="Integrarea modelelor de limbaj și a AI-ului în operațiunile organizației — procesare documente, asistenți interni, detectare anomalii și agenți în pipeline-uri DevOps."
            items={[
              'Procesare & clasificare automată documente',
              'Asistenți virtuali pentru helpdesk / HR',
              'Generare rapoarte & sumarizare LLM',
              'Agenți AI în pipeline-uri DevOps',
            ]}
            cols={1}
          >
            <Bot slot="icon" class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
          </ModuleCard>
        </div>

        <!-- 6. Consultanță arhitecturală + Staff aug -->
        <div data-reveal data-reveal-delay="160">
          <ModuleCard
            title="Consultanță & Staff Augmentation"
            index="06"
            body="Evaluare arhitecturi existente, strategii de adoptare cloud, definire DevSecOps — plus ingineri și arhitecți dedicați la dispoziția echipei tale."
            items={[
              'Evaluare arhitecturi & best practices',
              'Strategie adoptare cloud & migrare',
              'Ingineri dedicați (timp parțial sau full)',
              'Onboarding rapid, procese standardizate',
            ]}
            cols={1}
          >
            <Users slot="icon" class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
          </ModuleCard>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       BLOCKCHAIN — detaliu pragmatic (light band)
       ═══════════════════════════════════════════════════════════ -->
  <section class="bg-surface py-[72px] sm:py-[110px]">
    <div class="container">
      <div class="grid gap-16 lg:grid-cols-2 lg:items-start">
        <!-- Left: text -->
        <div data-reveal>
          <SectionHeading
            eyebrow="Blockchain enterprise"
            heading="Unde blockchain are sens — și unde nu"
            headingMaxWidth="520px"
          >
            Smart Control nu propune blockchain acolo unde o bază de date relațională tradițională
            este suficientă. Fiecare proiect pornește de la o analiză cost-beneficiu riguroasă.
          </SectionHeading>

          <div class="mt-8">
            <p class="text-[14.5px] leading-[1.7] text-cool">
              Expertiza noastră acoperă atât consultanța pentru identificarea cazurilor de utilizare
              potrivite, cât și livrarea end-to-end cu audit de securitate inclus.
            </p>
          </div>

          <div class="mt-8">
            <p class="mb-3 font-mono text-[11.5px] uppercase tracking-[2px] text-royal">
              Cazuri de utilizare reale
            </p>
            <ChevronList
              items={[
                'Tokenizare active digitale — transfer de proprietate automatizat prin smart contracts',
                'Control acces prin token-uri on-chain — auditabil și revocabil fără intervenție centralizată',
                'Aplicații descentralizate (dApps) — logică de business implementată on-chain',
                'Audit și remediere contracte inteligente — analiză statică și dinamică înainte de producție',
              ]}
              cols={1}
            />
          </div>
        </div>

        <!-- Right: tech pills + abordare -->
        <div data-reveal data-reveal-delay="120" data-drift="0.05">
          <div
            class="rounded-xl border border-border bg-page p-8 shadow-sm"
          >
            <p class="font-mono text-[11.5px] uppercase tracking-[2px] text-royal">
              Tehnologii & concepte
            </p>
            <div class="mt-4 flex flex-wrap gap-2">
              {
                [
                  'Hyperledger Fabric',
                  'Multichain',
                  'Smart Contracts',
                  'ERC-721 (NFT)',
                  'ERC-20 Tokens',
                  'Access Control On-chain',
                  'dApps',
                  'Privacy-Preserving Computation',
                ].map((tag) => (
                  <MonoPill>{tag}</MonoPill>
                ))
              }
            </div>

            <div class="mt-8 border-t border-border pt-6">
              <p class="font-mono text-[11.5px] uppercase tracking-[2px] text-royal">
                Abordare pragmatică
              </p>
              <p class="mt-3 text-[14px] leading-[1.7] text-cool">
                Blockchain aduce valoare reală acolo unde trasabilitatea, imutabilitatea sau
                automatizarea contractuală sunt cerințe reale — nu acolo unde e suficientă o bază de
                date relațională. Livrăm soluții testate, integrate și auditate.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       AI / LLM — detaliu (wash band)
       ═══════════════════════════════════════════════════════════ -->
  <section class="bg-page py-[72px] sm:py-[110px]">
    <div class="container">
      <div data-reveal>
        <SectionHeading
          eyebrow="Automatizare inteligentă"
          heading="AI integrat în operațiunile organizației"
          headingMaxWidth="640px"
        >
          Smart Control extinde capabilitățile de Software Development cu soluții de automatizare
          inteligentă — integrarea modelelor AI în fluxurile operaționale existente, cu metrici
          clare de livrare.
        </SectionHeading>
      </div>

      <div class="mt-11 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        <!-- Tipuri de automatizare -->
        {
          [
            {
              title: 'Procesare documente',
              body: 'Clasificare automată a facturilor, contractelor și formularelor cu extragere structurată de date.',
              Icon: FileText,
              delay: 0,
            },
            {
              title: 'Asistenți virtuali interni',
              body: 'Chatboți pentru suport IT helpdesk, HR și operațiuni — complementari serviciului de Service Desk.',
              Icon: MessageSquare,
              delay: 80,
            },
            {
              title: 'Raportare automată',
              body: 'Generare rapoarte și sumarizare documente lungi prin modele de limbaj (LLM), cu export configurat.',
              Icon: FileChartColumn,
              delay: 160,
            },
            {
              title: 'Fluxuri de aprobare AI',
              body: 'Automatizarea fluxurilor de aprobare și decizii bazate pe reguli combinate cu inferențe AI.',
              Icon: Workflow,
              delay: 0,
            },
            {
              title: 'Detectare anomalii',
              body: 'Alertare proactivă în procese operaționale — integrată cu platforma de monitorizare Smart Control.',
              Icon: TriangleAlert,
              delay: 80,
            },
            {
              title: 'Agenți AI în DevOps',
              body: 'Integrare agenți AI în pipeline-uri DevOps pentru code review automat, testare și documentare.',
              Icon: Bot,
              delay: 160,
            },
          ].map((item) => (
            <div
              data-reveal
              data-reveal-delay={item.delay > 0 ? String(item.delay) : undefined}
            >
              <div class="h-full rounded-xl border border-border bg-surface p-[26px] shadow-sm transition-all duration-[350ms] ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-[5px] hover:border-border-blue hover:shadow-lg">
                <div class="flex h-11 w-11 items-center justify-center rounded-md border border-border-blue bg-blue-wash">
                  <item.Icon class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
                </div>
                <h3 class="mt-[18px] text-[16px] font-bold text-navy">{item.title}</h3>
                <p class="mt-2.5 text-[13.5px] leading-[1.65] text-cool">{item.body}</p>
              </div>
            </div>
          ))
        }
      </div>

      <div class="mt-10" data-reveal>
        <div
          class="rounded-xl border border-border-blue bg-blue-wash p-6"
        >
          <p class="font-mono text-[11.5px] uppercase tracking-[2px] text-royal">
            Rezultate măsurabile
          </p>
          <p class="mt-2 text-[14.5px] leading-[1.7] text-slate">
            Proiectele de automatizare cu AI livrate de Smart Control urmăresc metrici clare:
            reducerea timpului de procesare, scăderea ratei de eroare și eliberarea capacității
            umane pentru activități cu valoare adăugată ridicată.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       STAFF AUGMENTATION — light band
       ═══════════════════════════════════════════════════════════ -->
  <section class="bg-surface py-[72px] sm:py-[110px]">
    <div class="container">
      <div class="grid gap-16 lg:grid-cols-2 lg:items-center">
        <div data-reveal>
          <SectionHeading
            eyebrow="Resurse tehnice dedicate"
            heading="Staff Augmentation — specialiști interni la dispoziția ta"
            headingMaxWidth="540px"
          >
            Punem la dispoziție ingineri și arhitecți IT pe bază de contract de servicii — timp
            parțial sau dedicat — pentru extinderea echipelor interne ale clienților.
          </SectionHeading>
          <div class="mt-8">
            <ChevronList
              items={[
                'Ingineri și arhitecți cu experiență verificată în sute de proiecte',
                'Onboarding rapid datorită proceselor standardizate Smart Control',
                'Timp parțial sau dedicat — flexibil după nevoile proiectului',
                'Continuitate garantată — echipă internă, nu rețea de freelanceri',
              ]}
              cols={1}
            />
          </div>
          <div class="mt-8">
            <MailtoLink variant="button" subject={t('subject.assessment')}>
              {t('cta.assessment')}
            </MailtoLink>
          </div>
        </div>

        <div data-reveal data-reveal-delay="120" data-drift="0.05">
          <div class="grid grid-cols-2 gap-4">
            {
              [
                { value: '50', label: 'Specialiști interni' },
                { value: '500+', label: 'Ani experiență cumulată' },
                { value: '650+', label: 'Proiecte livrate' },
                { value: String(years) + '+', label: 'Ani pe piață' },
              ].map((stat) => (
                <div class="rounded-xl border border-border bg-page p-6 text-center shadow-sm">
                  <div class="font-mono text-[32px] font-bold leading-none text-navy">
                    {stat.value}
                  </div>
                  <div class="mt-2 text-[13px] text-cool">{stat.label}</div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       CROSS-SELL — Cloud & Modernization link
       ═══════════════════════════════════════════════════════════ -->
  <section class="bg-page py-[48px] sm:py-[64px]">
    <div class="container">
      <div
        class="flex flex-col items-start justify-between gap-6 rounded-xl border border-border bg-surface p-8 shadow-sm sm:flex-row sm:items-center"
        data-reveal
      >
        <div>
          <p class="font-mono text-[11.5px] uppercase tracking-[2px] text-royal">
            Serviciu conex
          </p>
          <p class="mt-1.5 text-[17px] font-bold text-navy">
            Cloud & Modernizare — metodologia în 5 etape
          </p>
