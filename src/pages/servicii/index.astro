---
// /servicii — Services hub (Template B-lite, light landing)
// RO version. EN twin at /en/servicii/index.astro
// Owned by: services-hub page agent. Do NOT edit shared components.
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import ModuleCard from '../../components/ModuleCard.astro';
import StatStrip from '../../components/StatStrip.astro';
import StatBlock from '../../components/StatBlock.astro';
import MonoPill from '../../components/MonoPill.astro';
import CtaBand from '../../components/CtaBand.astro';
import TextLink from '../../components/TextLink.astro';
import Eyebrow from '../../components/Eyebrow.astro';
import { Server, ShieldCheck, Code, Settings2 } from '@lucide/astro';
import { useTranslations, getLangFromUrl, localizedPath, yearsInBusiness, FOUNDED } from '../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const p = (path: string) => localizedPath(lang, path);
const years = yearsInBusiness(new Date().getUTCFullYear());

// 4 pillar cards — exact canonical names per CLAUDE.md
const pillars = [
  {
    index: '01',
    title: 'Infrastructură & Cloud',
    href: p('/servicii/cloud'),
    icon: Server,
    body: 'Proiectăm și consolidăm centre de date, infrastructuri hibride și soluții cloud — de la hardware-ul fizic până la orchestrare Kubernetes.',
    items: [
      'Data Center Design & Implementation',
      'Consolidare & Virtualizare',
      'Private Cloud & Hybrid Cloud',
      'Business Continuity & Disaster Recovery',
    ],
  },
  {
    index: '02',
    title: 'Securitate & Conformitate',
    href: p('/servicii/securitate'),
    icon: ShieldCheck,
    body: 'Apărăm infrastructuri enterprise cu un strat complet de securitate cibernetică — de la perimetru până la identitate — validat conform ISO 27001 și în conformitate cu NIS 2 și DORA.',
    items: [
      'Perimeter & End-point Security',
      'Enterprise SSO / PKI',
      'Cybersecurity & GDPR / NIS 2 Compliance',
      'Managed Security Operations',
    ],
  },
  {
    index: '03',
    title: 'Software & Automatizare',
    href: p('/servicii/software'),
    icon: Code,
    body: 'Construim, modernizăm și automatizăm aplicații enterprise — de la refactoring și containerizare, până la DevSecOps, blockchain și integrare AI.',
    items: [
      'Dezvoltare software custom & API',
      'DevOps / DevSecOps & CI/CD',
      'Migrare și modernizare aplicații',
      'Automatizare cu AI / LLM',
    ],
  },
  {
    index: '04',
    title: 'Servicii Gestionate',
    href: p('/servicii/managed'),
    icon: Settings2,
    body: 'Preluăm operarea continuă a infrastructurii și aplicațiilor tale — echipă proprie, nu subcontractori — cu SLA-uri clare și raportare transparentă.',
    items: [
      'Managed Infrastructure Operations',
      'Service Desk Outsourcing',
      'Cyber Security Managed Services',
      'Cloud Based System Support',
    ],
  },
];

// JSON-LD: Service list via ItemList
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  'name': 'Servicii Smart Control',
  'description': 'Portofoliu integrat de servicii IT enterprise — infrastructură, securitate, software și servicii gestionate.',
  'url': 'https://smartcontrol.ro/servicii/',
  'numberOfItems': 4,
  'itemListElement': [
    {
      '@type': 'ListItem',
      'position': 1,
      'item': {
        '@type': 'Service',
        'name': 'Infrastructură & Cloud',
        'description': 'Data Center Design, Consolidare & Virtualizare, Private Cloud & Hybrid Cloud, Business Continuity & Disaster Recovery.',
        'url': 'https://smartcontrol.ro/servicii/cloud/',
        'provider': { '@type': 'Organization', 'name': 'Smart Control SRL' },
      },
    },
    {
      '@type': 'ListItem',
      'position': 2,
      'item': {
        '@type': 'Service',
        'name': 'Securitate & Conformitate',
        'description': 'Perimeter & End-point Security, Enterprise SSO / PKI, Cybersecurity & GDPR / NIS 2 Compliance, Managed Security Operations.',
        'url': 'https://smartcontrol.ro/servicii/securitate/',
        'provider': { '@type': 'Organization', 'name': 'Smart Control SRL' },
      },
    },
    {
      '@type': 'ListItem',
      'position': 3,
      'item': {
        '@type': 'Service',
        'name': 'Software & Automatizare',
        'description': 'Dezvoltare software custom & API, DevOps / DevSecOps & CI/CD, Migrare și modernizare aplicații, Automatizare cu AI / LLM.',
        'url': 'https://smartcontrol.ro/servicii/software/',
        'provider': { '@type': 'Organization', 'name': 'Smart Control SRL' },
      },
    },
    {
      '@type': 'ListItem',
      'position': 4,
      'item': {
        '@type': 'Service',
        'name': 'Servicii Gestionate',
        'description': 'Managed Infrastructure Operations, Service Desk Outsourcing, Cyber Security Managed Services, Cloud Based System Support.',
        'url': 'https://smartcontrol.ro/servicii/managed/',
        'provider': { '@type': 'Organization', 'name': 'Smart Control SRL' },
      },
    },
  ],
};
---

<BaseLayout
  title="Servicii IT Enterprise — Smart Control"
  description="Portofoliu integrat de servicii IT: Infrastructură & Cloud, Securitate & Conformitate, Software & Automatizare, Servicii Gestionate. 650+ proiecte livrate, echipă proprie."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  {/* ── HERO (light, parallax blob) ───────────────────────────────── */}
  <header
    class="relative overflow-hidden"
    style="background: linear-gradient(180deg, #F3F6FC 0%, #FFFFFF 100%)"
  >
    {/* Decorative parallax blob */}
    <div
      class="pointer-events-none absolute inset-0"
      data-parallax="0.3"
      aria-hidden="true"
    >
      <div
        style="
          position:absolute;
          top:-140px;
          right:-120px;
          width:600px;
          height:600px;
          border-radius:999px;
          background:radial-gradient(circle, rgba(122,180,232,0.18), rgba(122,180,232,0) 65%);
          animation: scDriftA 18s ease-in-out infinite alternate;
        "
      ></div>
    </div>

    <div class="container" style="padding-top:160px; padding-bottom:100px">
      <div data-hero-scrub>
        <Eyebrow variant="hero">SERVICII</Eyebrow>

        <h1
          class="mt-6 font-extrabold leading-[1.1] tracking-[-1.8px] text-midnight"
          style="font-size: clamp(2.5rem, 2rem + 2.5vw, 4rem); max-width: 820px"
        >
          Un portofoliu integrat,<br />
          <span class="text-bright">de la infrastructura fizică până la cod.</span>
        </h1>

        <p
          class="mt-6 text-[18px] leading-[1.7] text-slate"
          style="max-width:600px"
          data-reveal
          data-reveal-delay="200"
        >
          Patru piloni de servicii, susținuți de <strong class="text-navy font-semibold">50 de specialiști interni</strong> — echipă proprie, nu subcontractori. Abordare consultativă, cod sursă inclus, raport ROI la 90 de zile.
        </p>

      </div>
    </div>
  </header>

  {/* ── 4 PILLAR CARDS ────────────────────────────────────────────── */}
  <section id="piloni" class="scroll-mt-24 bg-surface py-[72px] sm:py-[110px]">
    <div class="container">
      <div data-reveal class="mb-14">
        <SectionHeading
          eyebrow="Portofoliu"
          heading="Patru piloni de servicii enterprise"
          headingMaxWidth="680px"
        >
          Smart Control acoperă întregul spectru IT — de la hardware-ul fizic și virtualizare, până la securitate cibernetică și dezvoltare software custom. Toate serviciile sunt susținute de echipa proprie.
        </SectionHeading>
      </div>

      <div
        class="grid gap-5 sm:grid-cols-2"
        data-skew="4"
      >
        {
          pillars.map((pillar, i) => {
            const PillarIcon = pillar.icon;
            return (
              <div
                data-reveal
                data-reveal-delay={String(i * 80)}
                data-reveal-rotate={i % 2 === 0 ? '-4' : '4'}
              >
                <ModuleCard
                  title={pillar.title}
                  index={pillar.index}
                  body={pillar.body}
                  items={pillar.items}
                  cols={1}
                >
                  <PillarIcon
                    slot="icon"
                    class="h-[22px] w-[22px] text-navy"
                    stroke-width={1.5}
                  />
                  <div class="mt-5">
                    <TextLink href={pillar.href}>Explorează</TextLink>
                  </div>
                </ModuleCard>
              </div>
            );
          })
        }
      </div>
    </div>
  </section>

  {/* ── PROOF STRIP ───────────────────────────────────────────────── */}
  <section class="bg-page py-[72px] sm:py-[100px]" data-band>
    <div class="container">
      {/* ISO + Compliance badges — ISO roundels grouped distinct from the teal regulatory trio */}
      <div data-reveal class="mb-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
        <div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-3">
          <MonoPill>ISO 9001</MonoPill>
          <MonoPill>ISO 27001</MonoPill>
          <MonoPill>ISO 14001</MonoPill>
          <MonoPill>ISO 45001</MonoPill>
        </div>
        <div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-3">
          <MonoPill variant="compliance">GDPR</MonoPill>
          <MonoPill variant="compliance">NIS 2</MonoPill>
          <MonoPill variant="compliance">DORA</MonoPill>
        </div>
      </div>

      {/* Stats */}
      <StatStrip>
        <StatBlock value="650" count={650} suffix="+" caption="Proiecte livrate" />
        <StatBlock value="250" count={250} suffix="+" caption="Clienți satisfăcuți" />
        <StatBlock value="25" count={25} suffix="+" caption="Clienți internaționali" />
        <StatBlock value={String(years)} count={years} suffix="+" caption="Ani de experiență" />
      </StatStrip>

      {/* Trust proof */}
      <div data-reveal class="mt-12 text-center">
        <p class="text-[15px] text-cool">
          Fondată în {FOUNDED} · 50 de specialiști interni · 500+ ani de experiență cumulată · <span class="text-navy font-semibold">echipă proprie, nu subcontractori</span>
        </p>
      </div>
    </div>
  </section>

  {/* ── WHY SMART CONTROL (brief differentiation strip) ───────────── */}
  <section class="bg-surface py-[72px] sm:py-[100px]">
    <div class="container">
      <div data-reveal class="mb-12">
        <SectionHeading
          eyebrow="De ce Smart Control"
          heading="Avantaje care contează în proiecte reale"
          headingMaxWidth="640px"
        />
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          [
            {
              title: 'Echipă proprie, nu subcontractori',
              body: '50 de specialiști interni disponibili on-site și remote — același nivel de calitate, indiferent de proiect.',
            },
            {
              title: 'Abordare consultativă',
              body: 'Relații pe termen lung cu 250+ clienți — livrare bazată pe date reale, nu pe estimări teoretice.',
            },
            {
              title: 'Cod sursă inclus',
              body: 'Platformele proprietare (SEKNET, S-VPN, monitorizare) sunt livrate cu cod sursă — personalizare totală, fără dependență de vendor.',
            },
            {
              title: 'Certificări active',
              body: '4 sisteme de management certificate simultan: ISO 9001, ISO 27001, ISO 14001, ISO 45001.',
            },
            {
              title: 'Raport ROI la 90 de zile',
              body: 'Validăm beneficiile fiecărui proiect printr-un raport de performanță comparativ la 90 de zile post-implementare.',
            },
            {
              title: 'Conformitate NIS 2 · DORA · GDPR',
              body: 'Operăm și livrăm în deplină conformitate cu directivele UE — un avantaj direct pentru clienții din sectoare reglementate.',
            },
          ].map((item, i) => (
            <div
              class="rounded-xl border border-border bg-surface p-[28px] shadow-sm transition-all duration-[350ms] ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-[4px] hover:border-border-blue hover:shadow-lg"
              data-reveal
              data-reveal-delay={String((i % 3) * 80)}
            >
              <h3 class="text-[16px] font-bold text-navy">{item.title}</h3>
              <p class="mt-3 text-[13.5px] leading-relaxed text-cool">{item.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* ── DARK CTA BAND ─────────────────────────────────────────────── */}
  <CtaBand
    id="contact"
    eyebrow="Pașii următori"
    heading="Assessment inițial gratuit — 2 zile"
    cta={t('cta.assessment')}
    subject={t('subject.assessment')}
  >
    Identificăm împreună zona de interes prioritară și livrăm un raport de recomandări la final. Fără angajamente — decizia de a continua îți aparține.
  </CtaBand>
</BaseLayout>
