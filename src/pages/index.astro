---
// Home (RO) — /
// Built 1:1 with docs/build-specs/home.md, applying RESOLUTIONS.md rulings:
//  · ISO 27701 stripped (4 ISO badges only); GDPR/NIS2/DORA in compliance teal.
//  · "Asset Management" stripped — the Produse dual cards pair SEKNET ↔ S-VPN.
//  · Years computed from 2003; © year dynamic (handled in Footer).
//  · No email inputs (no-forms); CTAs go straight to obfuscated mailto.
//  · Body-size link text royal on light / sky on dark (AA) via TextLink/MailtoLink.
//  · data-skew kept verbatim but inert (initScrollLean not wired).
import BaseLayout from '../layouts/BaseLayout.astro';
import Eyebrow from '../components/Eyebrow.astro';
import SectionHeading from '../components/SectionHeading.astro';
import NetworkCanvas from '../components/NetworkCanvas.astro';
import CtaBand from '../components/CtaBand.astro';
import ModuleCard from '../components/ModuleCard.astro';
import StatStrip from '../components/StatStrip.astro';
import StatBlock from '../components/StatBlock.astro';
import MonoPill from '../components/MonoPill.astro';
import IconChip from '../components/IconChip.astro';
import LogoMarquee from '../components/LogoMarquee.astro';
import TextLink from '../components/TextLink.astro';
import MailtoLink from '../components/MailtoLink.astro';
import SeknetConsole from '../components/SeknetConsole.astro';
import CloudPipeline from '../components/CloudPipeline.astro';
import {
  getLangFromUrl,
  useTranslations,
  localizedPath,
  EMAIL_USER,
  EMAIL_DOMAIN,
  yearsInBusiness,
} from '../i18n/ui';
import { Server, ShieldCheck, Code, LifeBuoy, Shield, Lock } from '@lucide/astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const p = (path: string) => localizedPath(lang, path);
const years = yearsInBusiness(new Date().getUTCFullYear());

const title = 'Smart Control — Trusted Service Delivery Partner';
const description =
  'Infrastructură, securitate și software enterprise, execuție 100% in-house. ' +
  'Peste 650 de proiecte, 250+ clienți, 4 certificări ISO și conformitate GDPR · NIS 2 · DORA.';

// — JSON-LD: Organization —
const org = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Smart Control SRL',
  url: 'https://smartcontrol.ro',
  logo: 'https://smartcontrol.ro/smartcontrol-mark.png',
  email: 'office@smartcontrol.ro',
  foundingDate: '2003',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Intrarea Aviator Teodor Iliescu 37',
    postalCode: '011672',
    addressLocality: 'București',
    addressCountry: 'RO',
  },
};

// Hero headline, per word (verbatim from spec) — line 2 in bright blue.
const heroLine1 = [
  { word: 'Infrastructură.', delay: '0.25s' },
  { word: 'Securitate.', delay: '0.40s' },
  { word: 'Software.', delay: '0.55s' },
];
const heroLine2 = [
  { word: 'Execuție', delay: '0.75s' },
  { word: '100%', delay: '0.93s' },
  { word: 'in-house.', delay: '1.11s' },
];

const isoBadges = ['ISO 9001', 'ISO 27001', 'ISO 14001', 'ISO 45001'];
const frameworks = ['GDPR', 'NIS 2', 'DORA'];

const partners = [
  'Hitachi Vantara',
  'Commvault',
  'Fortinet',
  'Cisco',
  'Juniper',
  'Lenovo',
  'VMware',
  'Fujitsu',
  'Oracle',
  'Microsoft',
  'Palo Alto',
  'Hanasis',
  'IBM',
  'HPE',
  'DELL',
];

// SEKNET module chips (4 standard + Trap, the active-deception module).
const seknetChips = [
  { title: 'Identity', sub: 'SSO · FIDO2 · SCIM' },
  { title: 'Shield', sub: 'SIEM · IDS · MITRE' },
  { title: 'Insight', sub: 'ML · anomalii' },
  { title: 'View', sub: 'topologie · rapoarte' },
];

// SEKNET live console — attack-map metrics + seed log feed.
const consoleMetrics = [
  { label: 'Evenimente/s', value: '1 240', base: 1240 },
  { label: 'Blocate', value: '1 240', base: 1240, accent: true },
  { label: 'Honeypot-uri', value: '20+' },
];
const consoleLog = [
  { time: '08:14:02', msg: 'IDS · scanare porturi blocată — 203.0.113.7' },
  { time: '08:14:05', msg: 'Trap · honeypot SSH atins — credențiale capturate' },
  { time: '08:14:09', msg: 'Identity · MFA FIDO2 validat — sesiune autorizată', blocked: false },
  { time: '08:14:11', msg: 'Shield · regulă MITRE T1110 declanșată — brute-force' },
  { time: '08:14:15', msg: 'Insight · anomalie trafic — host izolat' },
  { time: '08:14:18', msg: 'View · topologie actualizată — 142 noduri', blocked: false },
];

// Cloud & Modernization — 5-stage methodology, teaser pipeline.
const cloudSteps = [
  { title: 'Evaluare', sub: 'assessment 2 zile' },
  { title: 'Re-arhitecturare', sub: 'design țintă' },
  { title: 'Containerizare', sub: 'K8s / OpenShift' },
  { title: 'Migrare', sub: 'zero-downtime' },
  { title: 'Validare ROI', sub: 'raport 90 zile' },
];

const cloudRows = [
  {
    tag: 'CAPEX→OPEX',
    body: 'Migrarea investițiilor hardware spre modele cloud sau hibrid, cu costuri predictibile.',
  },
  {
    tag: 'K8S-READY',
    body: 'Containerizare și migrare pe Kubernetes / OpenShift / AKS / GKE, cu zero-downtime.',
  },
  {
    tag: 'ROI 90 ZILE',
    body: 'Validarea investiției printr-un raport de performanță la 90 de zile — date reale, nu estimări.',
  },
];
---

<BaseLayout title={title} description={description}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(org)} />

  {/* ── SECTION 2 — Hero (light) ── */}
  <header
    class="relative overflow-hidden"
    style="background:linear-gradient(180deg,#F3F6FC 0%,#FFFFFF 100%)"
  >
    {/* Parallax blob A */}
    <div data-parallax="0.35" class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div
        class="absolute h-[640px] w-[640px] rounded-full"
        style="top:-180px;left:-120px;background:radial-gradient(circle,rgba(122,180,232,0.22),rgba(122,180,232,0) 65%);animation:scDriftA 16s ease-in-out infinite alternate"
      >
      </div>
    </div>
    {/* Parallax blob B */}
    <div data-parallax="0.2" class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div
        class="absolute h-[720px] w-[720px] rounded-full"
        style="top:60px;right:-200px;background:radial-gradient(circle,rgba(68,135,220,0.14),rgba(68,135,220,0) 65%);animation:scDriftB 20s ease-in-out infinite alternate"
      >
      </div>
    </div>
    {/* Faint hero network */}
    <NetworkCanvas lineAlpha={0.1} dotAlpha={0.3} spread={26000} lineDist={140} speed={0.12} />

    <div
      data-hero-scrub
      class="relative z-[1] mx-auto max-w-[1180px] px-6 pb-[110px] pt-[150px] md:px-10 md:pt-[190px]"
    >
      <Eyebrow class="opacity-0 [animation:scFadeIn_0.8s_ease-out_0.1s_forwards]">
        Trusted Service Delivery Partner
      </Eyebrow>

      <h1
        class="mt-7 max-w-[860px] text-[clamp(2.4rem,1.6rem+3.6vw,4rem)] font-extrabold leading-[1.08] tracking-[-2px] text-midnight"
      >
        {
          heroLine1.map(({ word, delay }) => (
            <span
              class="mr-[0.28em] inline-block opacity-0"
              style={`animation:scWordIn 0.7s cubic-bezier(0.16,1,0.3,1) ${delay} forwards`}
            >
              {word}
            </span>
          ))
        }
        <br />
        {
          heroLine2.map(({ word, delay }) => (
            <span
              class="mr-[0.28em] inline-block text-bright opacity-0"
              style={`animation:scWordIn 0.7s cubic-bezier(0.16,1,0.3,1) ${delay} forwards`}
            >
              {word}
            </span>
          ))
        }
      </h1>

      <p
        class="mt-7 max-w-[600px] text-[18px] leading-[1.7] text-slate opacity-0 [animation:scFadeIn_0.9s_ease-out_1.3s_forwards]"
      >
        Smart Control dezvoltă, operează și protejează infrastructuri IT complexe de peste {years} de
        ani, deservind un portofoliu extins de clienți locali și internaționali. Garantăm
        continuitatea și calitatea business-ului prin utilizarea exclusivă a unei{' '}
        <strong class="font-semibold text-navy">echipe proprii de experți</strong>, o metodologie
        consultativă și o cultură organizațională fundamentată pe date reale.
      </p>

      <div
        class="mt-10 flex flex-wrap gap-2.5 opacity-0 [animation:scFadeIn_0.9s_ease-out_1.5s_forwards]"
      >
        {isoBadges.map((b) => <MonoPill>{b}</MonoPill>)}
        {frameworks.map((f) => <MonoPill variant="compliance">{f}</MonoPill>)}
      </div>
    </div>
  </header>

  {/* ── SECTION 3 — Statistici (count-up) ── */}
  <section class="px-6 pt-[56px] sm:pt-[72px] md:px-10">
    <div class="mx-auto max-w-[1180px]">
      <div data-drift="-0.05">
        <StatStrip>
          <StatBlock value="650" count={650} suffix="+" caption="Proiecte livrate" />
          <StatBlock value="250" count={250} suffix="+" caption="Clienți satisfăcuți" />
          <StatBlock value="25" count={25} suffix="+" caption="Clienți internaționali" />
          <StatBlock
            value={String(years)}
            count={years}
            suffix="+"
            caption="Ani de experiență"
          />
        </StatStrip>
      </div>
    </div>
  </section>

  {/* ── SECTION 4 — Servicii (bento, light) ── */}
  <section id="servicii" class="px-6 py-[72px] sm:py-[110px] md:px-10">
    <div class="mx-auto max-w-[1180px]">
      <div data-reveal>
        <SectionHeading
          eyebrow="Servicii"
          heading="Un portofoliu integrat, de la arhitectura hardware până la nivelul de aplicație"
          headingMaxWidth="700px"
        >
          Patru piloni de servicii, susținuți de 50 de specialiști interni cu peste 500 de ani de
          experiență cumulată — on-site și remote, același nivel de calitate.
        </SectionHeading>
      </div>

      <div
        data-skew="4"
        class="mt-[52px] grid grid-cols-1 gap-5 md:grid-cols-12"
      >
        {/* Card 01 — span 7 */}
        <div
          data-reveal
          data-reveal-rotate="-4"
          data-drift="0.07"
          class="md:col-span-12 lg:col-span-7"
        >
          <ModuleCard
            title="Infrastructură & Cloud"
            index="01"
            body="Proiectăm și consolidăm centre de date, virtualizăm și operăm medii private, hibride și cloud."
            items={[
              'Data Center Design & Implementation',
              'Consolidare & Virtualizare',
              'Private & Hybrid Cloud',
              'Business Continuity & DR',
              'Storage & Information Management',
              'Infrastructure Management',
            ]}
            cols={2}
          >
            <Server slot="icon" class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
          </ModuleCard>
        </div>

        {/* Card 02 — span 5 */}
        <div
          data-reveal
          data-reveal-delay="100"
          data-reveal-rotate="4"
          data-drift="-0.07"
          class="md:col-span-12 lg:col-span-5"
        >
          <ModuleCard
            title="Securitate & Conformitate"
            index="02"
            body="Securitate perimetrală și end-point, identitate și operațiuni de securitate gestionate."
            items={[
              'Perimeter & End-point Security',
              'Enterprise SSO / PKI',
              'Data Leakage Prevention · WAF',
              'Conformitate GDPR / NIS 2',
              'Managed Security Operations',
            ]}
            cols={1}
          >
            <ShieldCheck slot="icon" class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
          </ModuleCard>
        </div>

        {/* Card 03 — span 5 */}
        <div
          data-reveal
          data-reveal-rotate="4"
          data-drift="0.07"
          class="md:col-span-12 lg:col-span-5"
        >
          <ModuleCard
            title="Software & Automatizare"
            index="03"
            body="Dezvoltare custom, modernizare aplicații și automatizare cu AI — livrare DevSecOps."
            items={[
              'Dezvoltare software custom & API',
              'DevOps / DevSecOps & CI/CD',
              'Migrare și modernizare aplicații',
              'Blockchain (Hyperledger, Multichain)',
              'Automatizare cu AI / LLM',
            ]}
            cols={1}
          >
            <Code slot="icon" class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
          </ModuleCard>
        </div>

        {/* Card 04 — span 7 */}
        <div
          data-reveal
          data-reveal-delay="100"
          data-reveal-rotate="-4"
          data-drift="-0.07"
          class="md:col-span-12 lg:col-span-7"
        >
          <ModuleCard
            title="Servicii Gestionate"
            index="04"
            body="Operăm infrastructura, rețeaua și securitatea cibernetică — service desk și suport on-site & remote."
            items={[
              'Service Desk Outsourcing',
              'Managed Infrastructure Operations',
              'Network Managed Services',
              'Cyber Security Managed Services',
              'Outsourced Systems Support',
              'Cloud Based System Support',
            ]}
            cols={2}
          >
            <LifeBuoy slot="icon" class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
          </ModuleCard>
        </div>
      </div>
    </div>
  </section>

  {/* ── SECTION 5 — Produse (DARK band) ── */}
  <section
    id="produse"
    data-band
    class="relative overflow-hidden bg-midnight px-6 py-[72px] sm:py-[110px] md:px-10"
  >
    <NetworkCanvas
      lineAlpha={0.22}
      dotAlpha={0.55}
      spread={20000}
      lineDist={150}
      opacity={0.65}
    />
    <div
      class="pointer-events-none absolute inset-0"
      style="background:radial-gradient(ellipse 70% 60% at 70% 30%, rgba(68,135,220,0.14), rgba(4,12,43,0) 70%)"
      aria-hidden="true"
    >
    </div>

    <div class="relative z-[1] mx-auto max-w-[1180px]">
      {/* Top split grid */}
      <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-[1fr_1.05fr] lg:gap-16">
        {/* Left column — heading, CTAs, module chips */}
        <div data-reveal>
          <SectionHeading
            eyebrow="Produse proprietare"
            heading="SEKNET — monitorizare și securitate dintr-o singură consolă"
            variant="dark"
          >
            Platformă enterprise integrată: vizibilitate completă, detectare avansată a amenințărilor
            și management granular al identității. Cinci module specializate, o singură sursă de
            adevăr — acum cu SEKNET Trap, modulul de decepție activă.
          </SectionHeading>
          <div class="mt-7 flex flex-wrap items-center gap-5">
            <a
              href={p('/solutii/seknet')}
              class="inline-flex items-center gap-2 rounded-md bg-royal px-6 py-3 text-[14.5px] font-semibold text-white transition-all [box-shadow:0_0_28px_rgba(68,135,220,0.4)] hover:bg-navy hover:[box-shadow:0_0_40px_rgba(68,135,220,0.6)]"
            >
              Explorează SEKNET <span aria-hidden="true">›</span>
            </a>
            <TextLink href={p('/solutii/s-vpn')} dark>Explorează S-VPN</TextLink>
          </div>

          {/* module chips (4 standard + Trap) */}
          <div class="mt-8 flex flex-wrap gap-2">
            {
              seknetChips.map(({ title: cTitle, sub }) => (
                <div class="flex items-center gap-2 rounded-md border border-[rgba(122,180,232,0.18)] bg-[rgba(255,255,255,0.03)] px-3 py-2">
                  <span class="text-[13.5px] font-bold text-white">{cTitle}</span>
                  <span class="font-mono text-[10.5px] text-[rgba(226,233,245,0.5)]">{sub}</span>
                </div>
              ))
            }
            <div class="flex items-center gap-2 rounded-md border border-[rgba(68,135,220,0.45)] bg-[rgba(68,135,220,0.12)] px-3 py-2">
              <span class="text-[13.5px] font-bold text-white">Trap</span>
              <MonoPill variant="dark" class="!text-[10px] !tracking-[1px]">Nou</MonoPill>
            </div>
          </div>
        </div>

        {/* Right column — live attack-map console */}
        <div data-reveal data-reveal-delay="120" data-drift="-0.05">
          <SeknetConsole
            title="SEKNET TRAP · HARTĂ DE ATAC LIVE"
            metrics={consoleMetrics}
            log={consoleLog}
          />
        </div>
      </div>

      {/* Bottom dual cards — SEKNET ↔ S-VPN (Asset Management stripped) */}
      <div data-reveal class="mt-14 grid grid-cols-1 gap-5 md:grid-cols-2">
        {/* Card A — SEKNET (link) */}
        <a
          href={p('/solutii/seknet')}
          class="flex items-start gap-[18px] rounded-lg border border-[rgba(122,180,232,0.18)] bg-[rgba(255,255,255,0.03)] px-7 py-6 transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-1 hover:border-[rgba(68,135,220,0.55)] hover:[box-shadow:0_0_28px_rgba(68,135,220,0.18)]"
        >
          <IconChip variant="dark" size={40} class="shrink-0">
            <Shield class="h-5 w-5 text-sky" stroke-width={1.5} />
          </IconChip>
          <div>
            <div class="text-[15.5px] font-bold text-white">SEKNET</div>
            <p class="mt-1.5 text-[13.5px] leading-[1.6] text-[rgba(226,233,245,0.6)]">
              Platformă proprietară de monitorizare și securitate — SIEM, detecție bazată pe ML,
              identitate și decepție activă, într-o singură consolă. Cod sursă inclus.
            </p>
            <span class="mt-2.5 inline-block text-[13px] font-semibold text-sky"
              >Explorează SEKNET ›</span
            >
          </div>
        </a>

        {/* Card B — S-VPN (link) */}
        <a
          href={p('/solutii/s-vpn')}
          class="flex items-start gap-[18px] rounded-lg border border-[rgba(122,180,232,0.18)] bg-[rgba(255,255,255,0.03)] px-7 py-6 transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-1 hover:border-[rgba(68,135,220,0.55)] hover:[box-shadow:0_0_28px_rgba(68,135,220,0.18)]"
        >
          <IconChip variant="dark" size={40} class="shrink-0">
            <Lock class="h-5 w-5 text-sky" stroke-width={1.5} />
          </IconChip>
          <div>
            <div class="text-[15.5px] font-bold text-white">S-VPN</div>
            <p class="mt-1.5 text-[13.5px] leading-[1.6] text-[rgba(226,233,245,0.6)]">
              Suită integrată de acces remote securizat — VPN, MFA, WAF, Endpoint și Console, la
              −60% față de soluțiile tradiționale.
            </p>
            <span class="mt-2.5 inline-block text-[13px] font-semibold text-sky"
              >Explorează S-VPN ›</span
            >
          </div>
        </a>
      </div>
    </div>
  </section>

  {/* ── SECTION 6 — Cloud teaser (light wash) ── */}
  <section data-band class="bg-page px-6 py-[72px] sm:py-[110px] md:px-10">
    <div class="mx-auto max-w-[1180px]">
      {/* Header split — heading left, context + CTA right */}
      <div data-reveal class="grid grid-cols-1 items-end gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:gap-12">
        <SectionHeading
          eyebrow="Cloud & Modernization"
          heading="De la investiții masive în hardware, la eficiență prin re-arhitecturare inteligentă"
        />
        <div>
          <p class="text-[16px] leading-[1.6] text-cool">
            Prețurile componentelor critice cresc sub presiunea cererii pentru infrastructură AI, iar
            bugetele de refresh nu mai ajung. Re-arhitecturarea devine strategia principală — livrată
            printr-un flux în <strong class="font-semibold text-navy">5 etape</strong>, validat în
            650+ proiecte.
          </p>
          <a
            href={p('/servicii/cloud')}
            class="mt-5 inline-flex items-center gap-2 rounded-md bg-navy px-6 py-3 text-[14.5px] font-semibold text-white transition-all hover:bg-midnight hover:[box-shadow:0_6px_20px_rgba(14,31,91,0.25)]"
          >
            Explorează Cloud & Modernization <span aria-hidden="true">›</span>
          </a>
        </div>
      </div>

      {/* 5-stage methodology pipeline */}
      <div data-reveal class="mt-12">
        <CloudPipeline steps={cloudSteps} />
      </div>

      {/* Capability cards */}
      <div data-reveal data-reveal-delay="120" class="mt-5 grid grid-cols-1 gap-5 sm:grid-cols-3">
        {
          cloudRows.map(({ tag, body }) => (
            <div class="rounded-lg border border-border bg-surface p-[26px] shadow-sm transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-[2px] hover:border-border-blue hover:shadow-lg">
              <span class="mb-3.5 inline-block rounded-sm bg-blue-wash px-2.5 py-1 font-mono text-[11.5px] tracking-[0.5px] text-royal">
                {tag}
              </span>
              <p class="text-[14.5px] leading-[1.55] text-slate">{body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* ── SECTION 7 — Parteneri (light marquee) ── */}
  <section id="parteneri" class="overflow-hidden bg-surface py-24">
    <div class="mx-auto max-w-[1180px] px-6 md:px-10">
      <div data-reveal class="text-center">
        <Eyebrow>Parteneri tehnologici</Eyebrow>
        <p class="mx-auto mt-5 max-w-[540px] text-[15.5px] text-cool">
          Parteneriate cu cei mai importanți producători din lume — soluții testate, suport
          garantat, roadmap clar.
        </p>
      </div>
    </div>
    <div data-skew="8" class="mt-11 [will-change:transform]">
      <LogoMarquee items={partners} />
    </div>
  </section>

  {/* ── SECTION 8 — CTA / Contact (DARK band) ── */}
  <CtaBand
    id="contact"
    eyebrow="Pașii următori"
    heading="Assessment inițial gratuit — 2 zile"
    cta="Solicită assessment-ul"
    subject={t('subject.assessment')}
  >
    Fără obligații contractuale. Identificăm împreună zona de interes prioritară și livrăm un raport de
    recomandări la final.
  </CtaBand>

  {/* Contact details (email + address, NO map) */}
  <section aria-label="Date de contact" class="bg-surface px-6 py-16 md:px-10">
    <div class="mx-auto grid max-w-[1180px] grid-cols-1 gap-8 sm:grid-cols-2">
      <div>
        <h2 class="font-mono text-[11px] font-semibold uppercase tracking-[2px] text-cool">
          Contact
        </h2>
