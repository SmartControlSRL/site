---
// /en/servicii — Services hub (Template B-lite, light landing)
// EN twin of /servicii/index.astro
// Owned by: services-hub page agent. Do NOT edit shared components.
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SectionHeading from '../../../components/SectionHeading.astro';
import ModuleCard from '../../../components/ModuleCard.astro';
import StatStrip from '../../../components/StatStrip.astro';
import StatBlock from '../../../components/StatBlock.astro';
import MonoPill from '../../../components/MonoPill.astro';
import CtaBand from '../../../components/CtaBand.astro';
import TextLink from '../../../components/TextLink.astro';
import Eyebrow from '../../../components/Eyebrow.astro';
import { Server, ShieldCheck, Code, Settings2 } from '@lucide/astro';
import { useTranslations, getLangFromUrl, localizedPath, yearsInBusiness, FOUNDED } from '../../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const p = (path: string) => localizedPath(lang, path);
const years = yearsInBusiness(new Date().getUTCFullYear());

// 4 pillar cards — EN canonical names per CLAUDE.md / ui.ts
const pillars = [
  {
    index: '01',
    title: 'Infrastructure & Cloud',
    href: p('/servicii/cloud'),
    icon: Server,
    body: 'We design and consolidate data centres, hybrid infrastructures and cloud solutions — from physical hardware to Kubernetes orchestration.',
    items: [
      'Data Center Design & Implementation',
      'Consolidation & Virtualisation',
      'Private Cloud & Hybrid Cloud',
      'Business Continuity & Disaster Recovery',
    ],
  },
  {
    index: '02',
    title: 'Security & Compliance',
    href: p('/servicii/securitate'),
    icon: ShieldCheck,
    body: 'We protect enterprise infrastructures with a full cybersecurity stack — from perimeter to identity — validated against ISO 27001, NIS 2 and DORA.',
    items: [
      'Perimeter & End-point Security',
      'Enterprise SSO / PKI',
      'Cybersecurity & GDPR / NIS 2 Compliance',
      'Managed Security Operations',
    ],
  },
  {
    index: '03',
    title: 'Software & Automation',
    href: p('/servicii/software'),
    icon: Code,
    body: 'We build, modernise and automate enterprise applications — from refactoring and containerisation to DevSecOps, blockchain and AI integration.',
    items: [
      'Custom software development & APIs',
      'DevOps / DevSecOps & CI/CD',
      'Application migration & modernisation',
      'AI / LLM automation',
    ],
  },
  {
    index: '04',
    title: 'Managed Services',
    href: p('/servicii/managed'),
    icon: Settings2,
    body: 'We take over the continuous operation of your infrastructure and applications — our own team, no subcontractors — with clear SLAs and transparent reporting.',
    items: [
      'Managed Infrastructure Operations',
      'Service Desk Outsourcing',
      'Cyber Security Managed Services',
      'Cloud Based System Support',
    ],
  },
];

// JSON-LD: Service list via ItemList (EN)
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  'name': 'Smart Control Services',
  'description': 'Integrated IT services portfolio — infrastructure, security, software and managed services.',
  'url': 'https://smartcontrol.ro/en/servicii',
  'numberOfItems': 4,
  'itemListElement': [
    {
      '@type': 'ListItem',
      'position': 1,
      'item': {
        '@type': 'Service',
        'name': 'Infrastructure & Cloud',
        'description': 'Data Center Design & Implementation, Consolidation & Virtualisation, Private Cloud & Hybrid Cloud, Business Continuity & Disaster Recovery.',
        'url': 'https://smartcontrol.ro/en/servicii/cloud',
        'provider': { '@type': 'Organization', 'name': 'Smart Control SRL' },
      },
    },
    {
      '@type': 'ListItem',
      'position': 2,
      'item': {
        '@type': 'Service',
        'name': 'Security & Compliance',
        'description': 'Perimeter & End-point Security, Enterprise SSO / PKI, Cybersecurity & GDPR / NIS 2 Compliance, Managed Security Operations.',
        'url': 'https://smartcontrol.ro/en/servicii/securitate',
        'provider': { '@type': 'Organization', 'name': 'Smart Control SRL' },
      },
    },
    {
      '@type': 'ListItem',
      'position': 3,
      'item': {
        '@type': 'Service',
        'name': 'Software & Automation',
        'description': 'Custom software development & APIs, DevOps / DevSecOps & CI/CD, Application migration & modernisation, AI / LLM automation.',
        'url': 'https://smartcontrol.ro/en/servicii/software',
        'provider': { '@type': 'Organization', 'name': 'Smart Control SRL' },
      },
    },
    {
      '@type': 'ListItem',
      'position': 4,
      'item': {
        '@type': 'Service',
        'name': 'Managed Services',
        'description': 'Managed Infrastructure Operations, Service Desk Outsourcing, Cyber Security Managed Services, Cloud Based System Support.',
        'url': 'https://smartcontrol.ro/en/servicii/managed',
        'provider': { '@type': 'Organization', 'name': 'Smart Control SRL' },
      },
    },
  ],
};
---

<BaseLayout
  title="Enterprise IT Services — Smart Control"
  description="Integrated IT services portfolio: Infrastructure & Cloud, Security & Compliance, Software & Automation, Managed Services. 650+ projects delivered, in-house team."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  {/* ── HERO (light, parallax blob) ───────────────────────────────── */}
  <header
    class="relative overflow-hidden"
    style="background: linear-gradient(180deg, #F3F6FC 0%, #FFFFFF 100%)"
  >
    {/* Decorative parallax blob */}
    <div
      class="pointer-events-none absolute inset-0"
      data-parallax="0.3"
      aria-hidden="true"
    >
      <div
        style="
          position:absolute;
          top:-140px;
          right:-120px;
          width:600px;
          height:600px;
          border-radius:999px;
          background:radial-gradient(circle, rgba(122,180,232,0.18), rgba(122,180,232,0) 65%);
          animation: scDriftA 18s ease-in-out infinite alternate;
        "
      ></div>
    </div>

    <div class="container" style="padding-top:160px; padding-bottom:100px">
      <div data-hero-scrub>
        <Eyebrow variant="hero">SERVICES</Eyebrow>

        <h1
          class="mt-6 font-extrabold leading-[1.1] tracking-[-1.8px] text-midnight"
          style="font-size: clamp(2.5rem, 2rem + 2.5vw, 4rem); max-width: 820px"
        >
          An integrated portfolio,<br />
          <span class="text-bright">from physical infrastructure to code.</span>
        </h1>

        <p
          class="mt-6 text-[18px] leading-[1.7] text-slate"
          style="max-width:600px"
          data-reveal
          data-reveal-delay="200"
        >
          Four service pillars, backed by <strong class="text-navy font-semibold">50 in-house specialists</strong> — our own team, no subcontractors. A consultative approach, source code included, ROI report at 90 days.
        </p>

        <div class="mt-10 flex flex-wrap gap-4" data-reveal data-reveal-delay="350">
          <a
            href="#pillars"
            class="inline-flex items-center gap-2 rounded-md bg-navy px-6 py-3 text-[14.5px] font-semibold text-white transition-all hover:bg-midnight"
            style="box-shadow:0 4px 18px rgba(14,31,91,0.2)"
          >
            Explore services
          </a>
          <a
            data-email-user="office"
            data-email-domain="smartcontrol.ro"
            data-email-subject="Free assessment"
            class="inline-flex items-center gap-2 rounded-md bg-bright px-6 py-3 text-[14.5px] font-semibold text-white transition-all hover:bg-royal"
            style="box-shadow:0 4px 18px rgba(68,135,220,0.3)"
          >
            {t('cta.assessment')}
          </a>
        </div>
      </div>
    </div>
  </header>

  {/* ── 4 PILLAR CARDS ────────────────────────────────────────────── */}
  <section id="pillars" class="bg-surface py-[100px]">
    <div class="container">
      <div data-reveal class="mb-14">
        <SectionHeading
          eyebrow="Portfolio"
          heading="Four enterprise service pillars"
          headingMaxWidth="680px"
        >
          Smart Control covers the full IT spectrum — from physical hardware and virtualisation to cybersecurity and custom software development. All services are backed by our own team.
        </SectionHeading>
      </div>

      <div
        class="grid gap-5 sm:grid-cols-2"
        data-skew="4"
      >
        {
          pillars.map((pillar, i) => {
            const PillarIcon = pillar.icon;
            return (
              <div
                data-reveal
                data-reveal-delay={String(i * 80)}
                data-reveal-rotate={i % 2 === 0 ? '-4' : '4'}
              >
                <ModuleCard
                  title={pillar.title}
                  index={pillar.index}
                  body={pillar.body}
                  items={pillar.items}
                  cols={1}
                >
                  <PillarIcon
                    slot="icon"
                    class="h-[22px] w-[22px] text-navy"
                    stroke-width={1.5}
                  />
                  <div class="mt-5">
                    <TextLink href={pillar.href}>Explore</TextLink>
                  </div>
                </ModuleCard>
              </div>
            );
          })
        }
      </div>
    </div>
  </section>

  {/* ── PROOF STRIP ───────────────────────────────────────────────── */}
  <section class="bg-page py-[80px]" data-band>
    <div class="container">
      {/* ISO + Compliance badges */}
      <div data-reveal class="mb-12 flex flex-wrap items-center justify-center gap-3">
        <MonoPill>ISO 9001</MonoPill>
        <MonoPill>ISO 27001</MonoPill>
        <MonoPill>ISO 14001</MonoPill>
        <MonoPill>ISO 45001</MonoPill>
        <MonoPill variant="compliance">GDPR</MonoPill>
        <MonoPill variant="compliance">NIS 2</MonoPill>
        <MonoPill variant="compliance">DORA</MonoPill>
      </div>

      {/* Stats */}
      <StatStrip>
        <StatBlock value="650" count={650} suffix="+" caption="Projects delivered" />
        <StatBlock value="250" count={250} suffix="+" caption="Satisfied clients" />
        <StatBlock value="25" count={25} suffix="+" caption="International clients" />
        <StatBlock value={String(years)} count={years} suffix="+" caption="Years of experience" />
      </StatStrip>

      {/* Trust proof */}
      <div data-reveal class="mt-12 text-center">
        <p class="text-[15px] text-cool">
          Founded in {FOUNDED} · 50 in-house specialists · 500+ cumulative years of experience · <span class="text-navy font-semibold">own team, no subcontractors</span>
        </p>
      </div>
    </div>
  </section>

  {/* ── WHY SMART CONTROL (brief differentiation strip) ───────────── */}
  <section class="bg-surface py-[80px]">
    <div class="container">
      <div data-reveal class="mb-12">
        <SectionHeading
          eyebrow="Why Smart Control"
          heading="Advantages that matter in real projects"
          headingMaxWidth="640px"
        />
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          [
            {
              title: 'Own team, no subcontractors',
              body: '50 in-house specialists available on-site and remote — the same level of quality, regardless of the project.',
            },
            {
              title: 'Consultative approach',
              body: 'Long-term relationships with 250+ clients — delivery based on real data, not theoretical estimates.',
            },
            {
              title: 'Source code included',
              body: 'Proprietary platforms (SEKNET, S-VPN, monitoring) are delivered with source code — full customisation, no vendor lock-in.',
            },
            {
              title: 'Active certifications',
              body: '4 management systems certified simultaneously: ISO 9001, ISO 27001, ISO 14001, ISO 45001.',
            },
            {
              title: 'ROI report at 90 days',
              body: 'We validate the benefits of each project with a comparative performance report at 90 days post-implementation.',
            },
            {
              title: 'NIS 2 · DORA · GDPR compliance',
              body: 'We operate and deliver in full compliance with EU directives — a direct advantage for clients in regulated sectors.',
            },
          ].map((item, i) => (
            <div
              class="rounded-xl border border-border bg-surface p-[28px] shadow-sm transition-all hover:-translate-y-[4px] hover:shadow-lg"
              data-reveal
              data-reveal-delay={String((i % 3) * 80)}
            >
              <h3 class="text-[16px] font-bold text-navy">{item.title}</h3>
              <p class="mt-3 text-[13.5px] leading-relaxed text-cool">{item.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* ── DARK CTA BAND ─────────────────────────────────────────────── */}
  <CtaBand
    id="contact"
    eyebrow="Next steps"
    heading="Free initial assessment — 2 days"
    cta={t('cta.assessment')}
    subject={t('subject.assessment')}
  >
    We identify the priority area of interest together and deliver a recommendations report at the end. No commitments — the decision to continue is yours.
  </CtaBand>
</BaseLayout>
