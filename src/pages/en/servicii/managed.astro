---
/**
 * /en/servicii/managed — Managed Services (EN twin)
 * Template B (lighter service page): light hero → capabilities bento →
 * SLA/coverage angle → cross-sell → dark CtaBand
 * JSON-LD: Service
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SectionHeading from '../../../components/SectionHeading.astro';
import Eyebrow from '../../../components/Eyebrow.astro';
import ModuleCard from '../../../components/ModuleCard.astro';
import StatStrip from '../../../components/StatStrip.astro';
import StatBlock from '../../../components/StatBlock.astro';
import ChevronList from '../../../components/ChevronList.astro';
import MonoPill from '../../../components/MonoPill.astro';
import IconChip from '../../../components/IconChip.astro';
import TextLink from '../../../components/TextLink.astro';
import CtaBand from '../../../components/CtaBand.astro';
import {
  getLangFromUrl,
  useTranslations,
  localizedPath,
  yearsInBusiness,
} from '../../../i18n/ui';

import {
  Headset,
  Server,
  Network,
  ShieldCheck,
  Wrench,
  Cloud,
  Bot,
  Clock,
  CircleCheck,
  FileText,
} from '@lucide/astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const p = (path: string) => localizedPath(lang, path);
const years = yearsInBusiness(new Date().getUTCFullYear());

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Managed Services — Smart Control',
  description:
    'Service Desk Outsourcing, Managed Infrastructure Operations, Cyber Security Managed Services, Outsourced Systems Support (on-site & remote), Cloud Based System Support and Software Automation for enterprise companies.',
  url: 'https://smartcontrol.ro/en/servicii/managed',
  provider: {
    '@type': 'Organization',
    name: 'Smart Control SRL',
    url: 'https://smartcontrol.ro',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Intrarea Aviator Teodor Iliescu 37',
      addressLocality: 'București',
      postalCode: '011672',
      addressCountry: 'RO',
    },
  },
  serviceType: 'Managed IT Services',
  areaServed: {
    '@type': 'Country',
    name: 'Romania',
  },
};

const capabilities = [
  {
    index: '01',
    title: 'Service Desk Outsourcing',
    body: 'We take over the full helpdesk function — L1, L2 and L3 — with our own team, contractually defined SLAs and monthly reporting. Same crew, regardless of project.',
    items: [
      'L1 / L2 / L3 user support',
      'ITSM ticketing (ServiceNow, Jira)',
      'Contractual SLA for response and resolution time',
      'Monthly performance reports',
    ],
    icon: Headset,
    iconClass: 'h-[22px] w-[22px] text-navy',
  },
  {
    index: '02',
    title: 'Managed Infrastructure Operations',
    body: 'We operate and maintain client infrastructure — servers, storage, virtualization — through proactive monitoring and intervention before incidents impact production.',
    items: [
      '24/7 monitoring of critical systems',
      'Patch management and planned updates',
      'Periodically verified backup & recovery',
      'Capacity planning and resource optimization',
    ],
    icon: Server,
    iconClass: 'h-[22px] w-[22px] text-navy',
  },
  {
    index: '03',
    title: 'Network Managed Services',
    body: 'We manage the network as a service: configuration, monitoring, troubleshooting and continuous optimization — with full visibility over traffic and incidents.',
    items: [
      'LAN/WAN traffic and availability monitoring',
      'Management of Cisco, Juniper, Fortinet equipment',
      'Firewall management and access policies',
      'VPN and site-to-site connectivity',
    ],
    icon: Network,
    iconClass: 'h-[22px] w-[22px] text-navy',
  },
  {
    index: '04',
    title: 'Cyber Security Managed Services',
    body: 'Outsourced SOC service: continuous security event monitoring, threat detection and incident response — backed by ISO 27001 certification.',
    items: [
      'SIEM monitoring and event correlation',
      'Incident detection and response (IR)',
      'NIS 2 / GDPR compliance reports',
      'Periodic vulnerability management',
    ],
    icon: ShieldCheck,
    iconClass: 'h-[22px] w-[22px] text-navy',
  },
  {
    index: '05',
    title: 'Outsourced Systems Support',
    body: 'On-site and remote technical support for client systems — with our own engineers, available on-site or connected remotely, within agreed SLAs.',
    items: [
      'On-site intervention within agreed SLA',
      'Secure remote access via S-VPN',
      'Hardware/software incident diagnosis and resolution',
      'Up-to-date configuration documentation',
    ],
    icon: Wrench,
    iconClass: 'h-[22px] w-[22px] text-navy',
  },
  {
    index: '06',
    title: 'Cloud Based System Support',
    body: 'We operate client cloud environments — AWS, Azure, GCP or private cloud — with proactive monitoring, cost governance and continuous resource optimization.',
    items: [
      'Operations and monitoring for AWS / Azure / GCP',
      'Cost governance and resource rightsizing',
      'Cloud security and compliance',
      'Migration support and hybrid integration',
    ],
    icon: Cloud,
    iconClass: 'h-[22px] w-[22px] text-navy',
  },
  {
    index: '07',
    title: 'Software Automation',
    body: 'We automate repetitive processes and workflows — from system integrations and automated reporting to AI assistants for helpdesk and operations.',
    items: [
      'Workflow automation and integrations',
      'Chatbots and virtual helpdesk assistants',
      'Automated reporting and document processing',
      'AI agents in DevOps pipelines',
    ],
    icon: Bot,
    iconClass: 'h-[22px] w-[22px] text-navy',
  },
];
---

<BaseLayout
  title="Managed Services — Smart Control"
  description="Service Desk Outsourcing, Managed Infrastructure Operations, Cyber Security Managed Services, Cloud Based System Support and Software Automation. Our own team, contractual SLA, 24/7."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- ═══════════════════════════════════════════════════════════
       HERO — light wash, gradient top→white
       ═══════════════════════════════════════════════════════════ -->
  <header
    class="relative overflow-hidden"
    style="background: linear-gradient(180deg, #F3F6FC 0%, #FFFFFF 100%)"
  >
    <!-- Decorative drift blob -->
    <div
      class="pointer-events-none absolute"
      style="top:-120px;right:-100px;width:560px;height:560px;border-radius:999px;background:radial-gradient(circle,rgba(122,180,232,0.18),rgba(122,180,232,0) 65%);animation:scDriftA 20s ease-in-out infinite alternate"
      aria-hidden="true"
    >
    </div>

    <div class="container py-[110px] pb-[90px]" data-hero-scrub>
      <div class="max-w-[860px]">
        <Eyebrow variant="light">Managed Services</Eyebrow>

        <h1
          class="mt-6 font-extrabold leading-[1.1] tracking-[-1.8px] text-midnight"
          style="font-size:clamp(2.5rem, 1.8rem + 3vw, 3.75rem)"
        >
          Your infrastructure,<br />
          <span class="text-bright">operated by our team.</span>
        </h1>

        <p
          class="mt-6 max-w-[620px] text-[18px] leading-[1.7] text-cool"
          style="animation:scFadeIn 0.9s ease-out 0.5s both"
        >
          We take over the operation, monitoring and security of your IT infrastructure —
          with <strong class="text-navy font-semibold">our own team, no subcontractors</strong>,
          contractual SLAs and {years}+ years of experience delivering enterprise services.
        </p>

        <div
          class="mt-9 flex flex-wrap items-center gap-4"
          style="animation:scFadeIn 0.9s ease-out 0.8s both"
        >
          <a
            data-email-user="office"
            data-email-domain="smartcontrol.ro"
            data-email-subject="Free assessment"
            class="inline-flex items-center justify-center rounded-md bg-royal px-[26px] py-[13px] text-[14.5px] font-semibold text-white transition-all [box-shadow:0_4px_18px_rgba(68,135,220,0.35)] hover:bg-navy hover:-translate-y-[1px] hover:[box-shadow:0_6px_24px_rgba(68,135,220,0.45)]"
          >
            Request assessment
          </a>
          <TextLink href="#capabilities">
            View capabilities
          </TextLink>
        </div>
      </div>
    </div>
  </header>

  <!-- ═══════════════════════════════════════════════════════════
       STATS STRIP
       ═══════════════════════════════════════════════════════════ -->
  <section class="bg-surface py-[44px] sm:py-[56px]" aria-label="Key figures">
    <div class="container">
      <StatStrip>
        <StatBlock value="650" count={650} suffix="+" caption="Projects delivered" numberSize={40} />
        <StatBlock value="250" count={250} suffix="+" caption="Satisfied clients" numberSize={40} />
        <StatBlock value="25" count={25} suffix="+" caption="International clients" numberSize={40} />
        <StatBlock
          value={String(years)}
          count={years}
          suffix="+"
          caption="Years of experience"
          numberSize={40}
        />
      </StatStrip>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       SLA / COVERAGE — proof angle
       ═══════════════════════════════════════════════════════════ -->
  <section class="bg-page py-[64px] sm:py-[90px]" data-band aria-labelledby="sla-heading">
    <div class="container">
      <div data-reveal>
        <SectionHeading
          eyebrow="Quality commitment"
          heading="Contractual SLA, in-house team, transparent reporting"
          variant="light"
          headingMaxWidth="740px"
          headingId="sla-heading"
        >
          Smart Control managed services are delivered by 50 in-house specialists —
          no subcontractors. Every engagement includes a contractually defined SLA, monthly
          reporting and escalation directly to the engineers operating the service.
        </SectionHeading>
      </div>

      <div
        class="mt-[52px] grid gap-5 sm:grid-cols-2 lg:grid-cols-3"
        data-skew="4"
      >
        <!-- Proof card: SLA -->
        <div
          class="rounded-xl border border-border bg-surface p-[30px] shadow-sm transition-all duration-[350ms] ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-[5px] hover:border-border-blue hover:shadow-lg"
          data-reveal
          data-reveal-rotate="-4"
          data-drift="0.07"
        >
          <IconChip>
            <Clock class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
          </IconChip>
          <h3 class="mt-5 text-[17px] font-bold text-navy">Contractual SLA</h3>
          <p class="mt-2.5 text-[14px] leading-[1.65] text-cool">
            Response and resolution times guaranteed by contract, with clear penalties —
            not verbal promises. Direct escalation to the engineering team.
          </p>
        </div>

        <!-- Proof card: in-house team -->
        <div
          class="rounded-xl border border-border bg-surface p-[30px] shadow-sm transition-all duration-[350ms] ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-[5px] hover:border-border-blue hover:shadow-lg"
          data-reveal
          data-reveal-delay="100"
          data-reveal-rotate="4"
        >
          <IconChip>
            <CircleCheck class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
          </IconChip>
          <h3 class="mt-5 text-[17px] font-bold text-navy">In-house team, no subcontractors</h3>
          <p class="mt-2.5 text-[14px] leading-[1.65] text-cool">
            50 in-house specialists with over 500 cumulative years of experience —
            available on-site and remote. Consistent quality across every project.
          </p>
        </div>

        <!-- Proof card: reporting -->
        <div
          class="rounded-xl border border-border bg-surface p-[30px] shadow-sm transition-all duration-[350ms] ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-[5px] hover:border-border-blue hover:shadow-lg"
          data-reveal
          data-reveal-delay="200"
          data-reveal-rotate="-4"
          data-drift="-0.07"
        >
          <IconChip>
            <FileText class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
          </IconChip>
          <h3 class="mt-5 text-[17px] font-bold text-navy">Transparent monthly reporting</h3>
          <p class="mt-2.5 text-[14px] leading-[1.65] text-cool">
            Monthly report with performance metrics, incidents handled, trends identified
            and optimization recommendations — a foundation for informed decisions.
          </p>
        </div>
      </div>

      <!-- Compliance badges -->
      <div class="mt-12 flex flex-wrap gap-2.5" data-reveal data-reveal-delay="150">
        <MonoPill>ISO 9001</MonoPill>
        <MonoPill>ISO 27001</MonoPill>
        <MonoPill>ISO 14001</MonoPill>
        <MonoPill>ISO 45001</MonoPill>
        <MonoPill variant="compliance">GDPR</MonoPill>
        <MonoPill variant="compliance">NIS 2</MonoPill>
        <MonoPill variant="compliance">DORA</MonoPill>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       CAPABILITIES BENTO (#capabilities)
       7 service cards in a responsive grid
       ═══════════════════════════════════════════════════════════ -->
  <section
    id="capabilities"
    class="bg-surface py-[72px] sm:py-[110px]"
    aria-labelledby="capabilities-heading"
  >
    <div class="container">
      <div data-reveal>
        <SectionHeading
          eyebrow="Capabilities"
          heading="What Smart Control managed services cover"
          variant="light"
          headingMaxWidth="700px"
          headingId="capabilities-heading"
        >
          Seven managed service domains, delivered by an in-house team with experience
          verified across hundreds of enterprise projects — from service desk to AI-powered
          automation.
        </SectionHeading>
      </div>

      <div
        class="mt-[44px] grid gap-5 sm:grid-cols-2 lg:grid-cols-3"
        data-skew="4"
      >
        {
          capabilities.map((cap, i) => {
            const CapIcon = cap.icon;
            return (
              <div
                data-reveal
                data-reveal-delay={String(i * 60)}
                data-reveal-rotate={i % 2 === 0 ? '-4' : '4'}
                data-drift={i % 2 === 0 ? '0.05' : '-0.05'}
              >
                <ModuleCard
                  title={cap.title}
                  index={cap.index}
                  body={cap.body}
                  items={cap.items}
                  cols={1}
                >
                  <CapIcon slot="icon" class={cap.iconClass} stroke-width={1.5} />
                </ModuleCard>
              </div>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       CROSS-SELL — SEKNET + S-VPN
       ═══════════════════════════════════════════════════════════ -->
  <section class="bg-page py-[64px] sm:py-[90px]" aria-labelledby="crosssell-heading">
    <div class="container">
      <div data-reveal>
        <SectionHeading
          eyebrow="Proprietary solutions"
          heading="Managed services amplified by proprietary platforms"
          variant="light"
          headingMaxWidth="680px"
          headingId="crosssell-heading"
        >
          Smart Control managed services work with existing infrastructure too —
          but gain an extra dimension when combined with the SEKNET and S-VPN
          proprietary platforms.
        </SectionHeading>
      </div>

      <div class="mt-[44px] grid gap-5 sm:grid-cols-2" data-skew="4">
        <!-- SEKNET cross-sell -->
        <div
          class="rounded-xl border border-border bg-surface p-[34px] shadow-sm transition-all duration-[350ms] ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-[5px] hover:border-border-blue hover:shadow-lg"
          data-reveal
          data-reveal-rotate="-4"
          data-drift="0.07"
        >
          <div class="flex items-center gap-3">
            <IconChip>
              <ShieldCheck class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
            </IconChip>
            <div>
              <div class="font-mono text-[11px] uppercase tracking-[1.5px] text-royal">
                Proprietary solution
              </div>
              <h3 class="mt-0.5 text-[19px] font-bold tracking-[-0.3px] text-navy">SEKNET</h3>
            </div>
          </div>
          <p class="mt-4 text-[14px] leading-[1.65] text-cool">
            Our proprietary monitoring and cybersecurity platform — integrated directly
            into the managed security service. SIEM, IAM, threat detection and full
            visibility across your infrastructure.
          </p>
          <ChevronList
            items={[
              'Native SIEM monitoring',
              'Identity & Access Management',
              'Automated threat detection and response',
              '200+ predefined dashboards',
            ]}
            cols={1}
            class="mt-4"
          />
          <div class="mt-6">
            <TextLink href={p('/solutii/seknet')}>Explore SEKNET</TextLink>
          </div>
        </div>

        <!-- S-VPN cross-sell -->
        <div
          class="rounded-xl border border-border bg-surface p-[34px] shadow-sm transition-all duration-[350ms] ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-[5px] hover:border-border-blue hover:shadow-lg"
          data-reveal
          data-reveal-delay="100"
          data-reveal-rotate="4"
        >
          <div class="flex items-center gap-3">
            <IconChip>
              <Network class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
            </IconChip>
            <div>
              <div class="font-mono text-[11px] uppercase tracking-[1.5px] text-royal">
                Proprietary solution
              </div>
              <h3 class="mt-0.5 text-[19px] font-bold tracking-[-0.3px] text-navy">S-VPN</h3>
            </div>
          </div>
          <p class="mt-4 text-[14px] leading-[1.65] text-cool">
            Enterprise secure remote access — VPN, MFA, WAF and endpoint protection
            in a single proprietary solution. The technical backbone for remote
            support within SLA, with no third-party dependency.
          </p>
          <ChevronList
            items={[
              'Enterprise SSL & IPSec VPN',
              'MFA with 5 configurable methods',
              'Web Application Firewall included',
              '10,000+ simultaneous tunnels',
            ]}
            cols={1}
            class="mt-4"
          />
          <div class="mt-6">
            <TextLink href={p('/solutii/s-vpn')}>Explore S-VPN</TextLink>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       CTA BAND — dark
       ═══════════════════════════════════════════════════════════ -->
  <CtaBand
    id="contact"
    eyebrow="Next steps"
    heading="Free initial assessment — 2 days"
    cta={t('cta.assessment')}
    subject={t('subject.assessment')}
  >
    We assess the operational maturity of your infrastructure at no charge and identify
    the areas where managed services deliver the fastest ROI. No commitment —
    the decision to continue is entirely yours.
  </CtaBand>
</BaseLayout>
