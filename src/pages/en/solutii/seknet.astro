---
// SEKNET — product detail (Template A). EN twin at /en/solutii/seknet.
// Faithful translation of the RO page; technical terms stay English, sentence
// case headings, no marketing fluff. Same motion wiring + canvas opts.
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NetworkCanvas from '../../../components/NetworkCanvas.astro';
import SectionHeading from '../../../components/SectionHeading.astro';
import ModuleCard from '../../../components/ModuleCard.astro';
import SpecTable from '../../../components/SpecTable.astro';
import CtaBand from '../../../components/CtaBand.astro';
import MailtoLink from '../../../components/MailtoLink.astro';
import { getLangFromUrl, useTranslations, localizedPath } from '../../../i18n/ui';
import {
  FingerprintPattern,
  Shield,
  Activity,
  LayoutDashboard,
  Radar,
  CloudCog,
  Lock,
} from '@lucide/astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const p = (path: string) => localizedPath(lang, path);

const title = 'SEKNET — Monitoring, security and control | Smart Control';
const description =
  'SEKNET: an integrated enterprise platform for monitoring, cybersecurity and identity management — five specialized modules, cloud-native architecture, ≥ 50,000 EPS / node, scaling with no additional licensing costs.';

// Hero stat row (4 mono pills, ▸-prefixed).
const heroStats = [
  '≥ 50,000 EPS per node',
  '< 1s indexing latency',
  'Multi-tenancy, per-tenant isolation',
  'Unlimited historical storage',
];

// Mono spec table rows (translated, "·"-delimited). ISO 27701 NOT present.
const specRows = [
  {
    label: 'Performance',
    value:
      '≥ 50,000 EPS / node · indexing < 1s · search < 5s over 100 GB · alerting < 60s · agent overhead < 1% CPU',
  },
  {
    label: 'Scalability',
    value:
      '1,000+ concurrent sources · ≥ 10 GB/day with no cap · horizontal scaling with no downtime · multi-tenancy with full isolation',
  },
  {
    label: 'Continuity',
    value: 'RTO < 4h · RPO < 1h · failover < 30s · rolling updates without interruption · replication ≥ 2x',
  },
  {
    label: 'Security',
    value:
      'TLS 1.2 / 1.3 in transit · AES-256 at rest · tamper-proof audit log · secrets in vault (K8s Secrets) · CIS Level 1 hardening by default',
  },
  {
    label: 'Integrations',
    value:
      'REST API (OpenAPI/Swagger) · ServiceNow, Jira, Zendesk · SOAR — Splunk, IBM, TheHive · email, Slack, Teams, SNS, PagerDuty, webhooks',
  },
  {
    label: 'Deployment',
    value:
      'Cloud-native, containerized microservices · on-premise, hybrid or cloud (AWS, Azure, GCP) · agents for Windows, Linux, macOS, Solaris, AIX, HP-UX · ro-RO and en-US interface',
  },
];

// JSON-LD: Product (SEKNET, brand Smart Control) — no price.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'SEKNET',
  brand: { '@type': 'Brand', name: 'Smart Control' },
  category: 'Enterprise security & monitoring platform',
  description:
    'An integrated enterprise platform for monitoring, cybersecurity and identity management — five specialized modules (Identity, Shield, Insight, View, Trap), cloud-native microservices architecture.',
  url: 'https://smartcontrol.ro/en/solutii/seknet',
  manufacturer: { '@type': 'Organization', name: 'Smart Control SRL', url: 'https://smartcontrol.ro' },
};
---

<BaseLayout title={title} description={description}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  {/* ─── 2. PRODUCT HERO (dark + network) ─────────────────────────────── */}
  <header class="relative overflow-hidden bg-midnight">
    <NetworkCanvas lineAlpha={0.24} dotAlpha={0.6} spread={18000} lineDist={155} opacity={0.75} />
    <div
      class="pointer-events-none absolute inset-0"
      style="background:radial-gradient(ellipse 75% 65% at 35% 40%, rgba(4,12,43,0) 0%, rgba(4,12,43,0.5) 60%, #040C2B 100%)"
      aria-hidden="true"
    >
    </div>

    <div
      data-hero-scrub
      class="relative z-[1] mx-auto max-w-[1180px] px-6 pb-[120px] pt-[150px] sm:px-10 sm:pt-[190px]"
    >
      <span
        class="sc-hero-eyebrow inline-block border-b-2 border-[rgba(122,180,232,0.3)] pb-2.5 font-mono text-[12.5px] font-medium uppercase tracking-[2.5px] text-sky"
      >
        Proprietary product · Specification sheet v2.3
      </span>

      <h1
        class="mt-[26px] max-w-[840px] text-[clamp(2.5rem,1.9rem+2.6vw,3.875rem)] font-extrabold leading-[1.08] tracking-[-2px] text-white"
      >
        <span class="sc-word sc-word-1 inline-block text-white">SEKNET.</span>{' '}
        <span class="sc-word sc-word-2 inline-block text-sky">Monitoring.</span>
        <br />
        <span class="sc-word sc-word-3 inline-block text-sky">Security.</span>{' '}
        <span class="sc-word sc-word-4 inline-block text-sky">Control.</span>
      </h1>

      <p
        class="sc-hero-lead mt-[26px] max-w-[640px] text-[18px] leading-[1.7] text-[rgba(226,233,245,0.72)]"
      >
        An integrated enterprise platform for monitoring, cybersecurity and identity management —
        <strong class="font-semibold text-white">five specialized modules</strong>, a cloud-native
        microservices architecture, unlimited horizontal scaling <strong
          class="font-semibold text-white">with no additional licensing costs</strong
        >.
      </p>

      <div class="sc-hero-cta mt-[38px] flex flex-wrap items-center gap-4">
        <MailtoLink variant="button" dark subject={t('subject.demo.seknet')}>
          {t('cta.demo.seknet')}
        </MailtoLink>
        <a
          href="#module"
          class="px-2 py-[13px] text-[14.5px] font-semibold text-sky transition-colors hover:text-white"
        >
          See the modules <span aria-hidden="true">›</span>
        </a>
      </div>

      <ul class="sc-hero-stats mt-[56px] flex flex-wrap gap-x-5 gap-y-3 sm:gap-x-9">
        {
          heroStats.map((s) => (
            <li class="font-mono text-[12.5px] text-[rgba(226,233,245,0.55)]">
              <span class="text-sky" aria-hidden="true">
                ▸
              </span>{' '}
              {s}
            </li>
          ))
        }
      </ul>
    </div>
  </header>

  {/* ─── 3. MODULE (light deep-dive, 5 modules) ───────────────────────── */}
  <section id="module" class="bg-surface px-6 py-[110px] sm:px-10">
    <div class="mx-auto max-w-[1180px]">
      <div data-reveal>
        <SectionHeading
          eyebrow="Modules"
          heading="Five specialized modules, a single source of truth"
          variant="light"
          headingMaxWidth="720px"
        >
          50 functional and 30 non-functional specifications, documented in the v2.3 technical
          sheet — every capability belongs to a module, all operated from a single interface.
        </SectionHeading>
      </div>

      <div data-skew="4" class="mt-[52px] grid grid-cols-1 gap-5 md:grid-cols-6">
        {/* Card 1 — Identity (span 2) */}
        <div
          class="md:col-span-3 lg:col-span-2"
          data-reveal
          data-reveal-rotate="-4"
          data-drift="0.07"
        >
          <ModuleCard
            kicker="Seknet"
            title="Identity"
            body="Identity and access management (IAM)."
            items={[
              'SSO — OAuth2, OIDC, SAML 2.0',
              'MFA — TOTP, WebAuthn / FIDO2',
              'Granular RBAC + Segregation of Duties',
              'Native AD / LDAP / RADIUS',
              'Automated SCIM 2.0 provisioning',
            ]}
            cols={1}
          >
            <FingerprintPattern slot="icon" class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
          </ModuleCard>
        </div>

        {/* Card 2 — Shield (span 2) */}
        <div
          class="md:col-span-3 lg:col-span-2"
          data-reveal
          data-reveal-delay="80"
          data-reveal-rotate="4"
        >
          <ModuleCard
            kicker="Seknet"
            title="Shield"
            body="SIEM and cybersecurity."
            items={[
              'Multi-source correlation + MITRE ATT&CK',
              'IDS — signature and behavior based',
              'Real-time File Integrity Monitoring',
              'Threat intel — VirusTotal, OTX, MISP',
              'Active response — IP blocking, endpoint isolation',
            ]}
            cols={1}
          >
            <Shield slot="icon" class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
          </ModuleCard>
        </div>

        {/* Card 3 — Insight (span 2) */}
        <div
          class="md:col-span-6 lg:col-span-2"
          data-reveal
          data-reveal-delay="160"
          data-reveal-rotate="-4"
          data-drift="-0.07"
        >
          <ModuleCard
            kicker="Seknet"
            title="Insight"
            body="Data analysis, search and storage."
            items={[
              'Distributed search, real-time indexing',
              'Query DSL, Lucene or SQL',
              'Unlimited historical storage — zero cost / GB',
              'Native ML — spike & drop anomalies',
              'RESTful API — OpenAPI / Swagger',
            ]}
            cols={1}
          >
            <Activity slot="icon" class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
          </ModuleCard>
        </div>

        {/* Card 4 — View (span 3, two-column bullets) */}
        <div class="md:col-span-3" data-reveal data-reveal-rotate="4" data-drift="0.07">
          <ModuleCard
            kicker="Seknet"
            title="View"
            body="Unified interface and advanced RBAC."
            items={[
              '200+ predefined dashboards',
              'Interactive topology map',
              'Automated PDF / CSV reports',
              'Per-role view access',
              'Compliance with PCI-DSS, HIPAA, GDPR, NIS 2, ISO 27001',
            ]}
            cols={2}
          >
            <LayoutDashboard slot="icon" class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
          </ModuleCard>
        </div>

        {/* Card 5 — Trap (span 3, DARK featured) */}
        <div
          class="md:col-span-3"
          data-reveal
          data-reveal-delay="80"
          data-reveal-rotate="-4"
          data-drift="-0.07"
        >
          <ModuleCard variant="dark" kicker="Seknet" title="Trap" badge="New in v2.3" cols={2}>
            <Radar slot="icon" class="h-[22px] w-[22px] text-sky" stroke-width={1.5} />
            <p class="mt-4 text-[13.5px] text-[rgba(226,233,245,0.7)]">
              Active detection through deception and honeypots — any interaction is malicious by
              definition: <strong class="text-white">zero false positives</strong>.
            </p>
            <ul class="mt-4 grid gap-y-2 sm:grid-cols-2 sm:gap-x-6">
              {
                [
                  'Honeypots — 20+ protocols',
                  'Lateral movement detection',
                  'Session capture + IoC export',
                  'Network IDS — scan, exploit, C2',
                  'Live attack map with geolocation',
                  'LLM honeypots — simulated services',
                ].map((item) => (
                  <li class="flex text-[13.5px] leading-snug text-[rgba(226,233,245,0.85)]">
                    <span class="mr-2 shrink-0 text-sky" aria-hidden="true">
                      ›
                    </span>
                    <span>{item}</span>
                  </li>
                ))
              }
            </ul>
          </ModuleCard>
        </div>
      </div>
    </div>
  </section>

  {/* ─── 4. SPEC TABLE (mono, gray-wash band) ─────────────────────────── */}
  <section data-band class="bg-page px-6 py-[110px] sm:px-10">
    <div class="mx-auto max-w-[1180px]">
      <div data-reveal>
        <SectionHeading
          eyebrow="Specifications · v2.3"
          heading="Documented specifications, in black and white"
          variant="light"
        />
      </div>

      {/* Giant-number stat strip — static (NO data-count). */}
      <div
        class="mt-11 grid grid-cols-2 gap-px overflow-hidden rounded-xl border border-border bg-border shadow-sm md:grid-cols-4"
        data-reveal
      >
        {
          [
            { num: '50K', accent: '+', caption: 'Events / second / node' },
            { num: '<1', accent: 's', caption: 'Indexing latency' },
            { num: '10GB', accent: '+', caption: 'Daily ingest, no cap' },
            { num: '∞', accent: '', caption: 'Data retention — zero licensing cost' },
          ].map((cell) => (
            <div class="bg-surface px-7 py-7">
              <div class="font-mono text-[34px] font-semibold leading-none text-navy">
                {cell.num}
                {cell.accent && <span class="text-bright">{cell.accent}</span>}
              </div>
              <div class="mt-2.5 text-[13.5px] text-cool">{cell.caption}</div>
            </div>
          ))
        }
      </div>

      <div class="mt-5" data-reveal data-drift="-0.04">
        <SpecTable rows={specRows} />
      </div>
    </div>
  </section>

  {/* ─── 5. SAME FAMILY (cross-sell, light) ───────────────────────────── */}
  <section class="bg-surface px-6 py-[110px] sm:px-10">
    <div class="mx-auto max-w-[1180px]">
      <div data-reveal>
        <SectionHeading eyebrow="From the same family" heading="Complete the platform" variant="light" />
      </div>

      <div class="mt-11 grid grid-cols-1 gap-5 md:grid-cols-2">
        {/* Card A — S-VPN (clickable link card) */}
        <div data-reveal data-drift="0.06">
          <a
            href={p('/solutii/s-vpn')}
            class="group flex h-full items-start gap-5 rounded-xl border border-border bg-surface p-[30px] no-underline shadow-sm transition-all duration-[350ms] ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-[5px] hover:border-border-blue hover:shadow-lg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-bright sm:px-[34px]"
          >
            <span
              class="flex h-11 w-11 shrink-0 items-center justify-center rounded-md border border-border-blue bg-blue-wash"
            >
              <Lock class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
            </span>
            <span class="block">
              <span class="block text-[18px] font-bold text-navy">S-VPN</span>
              <span class="mt-2 block text-[14px] leading-[1.65] text-cool">
                An integrated secure remote-access suite — VPN, MFA, WAF, Endpoint and Console, at
                −60% versus Cisco / Fortinet.
              </span>
              <span class="mt-3 inline-block text-[13.5px] font-semibold text-royal">
                Explore S-VPN <span aria-hidden="true">›</span>
              </span>
            </span>
          </a>
        </div>

        {/* Card B — Cloud & Modernization cross-sell (Asset Management BANNED, RESOLUTIONS §9;
            Cloud chosen over a second S-VPN card to avoid duplicate targets) */}
        <div data-reveal data-reveal-delay="100" data-drift="-0.06">
          <a
            href={p('/servicii/cloud')}
            class="group flex h-full items-start gap-5 rounded-xl border border-border bg-surface p-[30px] no-underline shadow-sm transition-all duration-[350ms] ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-[5px] hover:border-border-blue hover:shadow-lg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-bright sm:px-[34px]"
          >
            <span
              class="flex h-11 w-11 shrink-0 items-center justify-center rounded-md border border-border-blue bg-blue-wash"
            >
              <CloudCog class="h-[22px] w-[22px] text-navy" stroke-width={1.5} />
            </span>
            <span class="block">
              <span class="block text-[18px] font-bold text-navy">Modernization with security built in</span>
              <span class="mt-2 block text-[14px] leading-[1.65] text-cool">
                We re-architect infrastructure with security integrated from day one — a 5-stage
                methodology, an ROI business case and a 90-day ROI report.
              </span>
              <span class="mt-3 inline-block text-[13.5px] font-semibold text-royal">
                Explore Cloud & Modernization <span aria-hidden="true">›</span>
              </span>
            </span>
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* ─── 6. CTA (dark band + network) ─────────────────────────────────── */}
  <CtaBand
    id="contact"
    eyebrow="Live demo"
    heading="See SEKNET on your own infrastructure"
    cta={t('cta.demo.seknet')}
    subject={t('subject.demo.seknet')}
  >
    A demo on a test environment with your real data — not a slide deck. We schedule within the
    same week.
  </CtaBand>
</BaseLayout>

<style>
  /* Hero entry animations (export <helmet>): the keyframes live in global.css;
     here we set the initial hidden state + staggered timings. Collapsed to a
     resting visible state under prefers-reduced-motion (handled globally). */
  .sc-hero-eyebrow {
    opacity: 0;
    animation: scFadeIn 0.8s ease-out 0.1s forwards;
  }
  .sc-word {
    opacity: 0;
    animation: scWordIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .sc-word-1 {
    animation-delay: 0.25s;
  }
  .sc-word-2 {
    animation-delay: 0.45s;
  }
  .sc-word-3 {
    animation-delay: 0.62s;
  }
  .sc-word-4 {
    animation-delay: 0.79s;
  }
  .sc-hero-lead {
    opacity: 0;
    animation: scFadeIn 0.9s ease-out 1s forwards;
  }
  .sc-hero-cta {
    opacity: 0;
    animation: scFadeIn 0.9s ease-out 1.2s forwards;
  }
  .sc-hero-stats {
    opacity: 0;
    animation: scFadeIn 0.9s ease-out 1.4s forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .sc-hero-eyebrow,
    .sc-word,
    .sc-hero-lead,
    .sc-hero-cta,
    .sc-hero-stats {
      opacity: 1;
    }
  }
</style>
